---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { programas, formatIndex } from "../../programas-temporales/programas";
---

<BaseLayout title="Catálogo de programas temporales">
  <main class="catalogo-shell" id="contenido-principal">
    <section class="catalogo-hero">
      <div>
        <p class="section-eyebrow">Programas temporales</p>
        <h1>Catálogo completo</h1>
        <p>Explora los laboratorios documentados con métricas, código y evidencia visual. Cada tarjeta abre la plantilla correspondiente.</p>
      </div>
      <a class="btn btn-ghost" href="/">Volver a la portada →</a>
    </section>

    <section>
      <div class="catalogo-esquemas" aria-label="Esquemas de contenidos">
        <span class="program-card__scheme-badge program-card__scheme-badge--algoritmos">Algoritmos</span>
        <span class="program-card__scheme-badge program-card__scheme-badge--estructuras">Estructuras de datos</span>
      </div>
      <div class="catalogo-grid">
        {programas.map((programa) => (
          <a class={`program-card program-card--${programa.esquema}`} href={programa.enlaceExterno} aria-label={`Abrir ${programa.titulo}`}>
            <div class="program-card__head">
              <div class="program-card__index">{formatIndex(programa.id)}</div>
              <span class={`program-card__scheme-badge program-card__scheme-badge--${programa.esquema}`}>
                {programa.esquema === "estructuras" ? "ESTRUCTURAS" : "ALGORITMOS"}
              </span>
            </div>
            <div class="program-card__title">{programa.titulo}</div>
            <p class="program-card__desc">{programa.descripcion}</p>
            {programa.tags && (
              <div class="program-card__tags">
                {programa.tags.slice(0, 3).map((tag) => (
                  <span class="pill">{tag}</span>
                ))}
              </div>
            )}
            <div class="program-card__cta">Ver programa →</div>
          </a>
        ))}
      </div>
    </section>

    <section class="catalog-back-actions ds-panel">
      <div>
        <p class="ds-eyebrow">Navegación de programas</p>
        <h2>Volver desde el catálogo</h2>
        <p>Regresa a la portada o continúa revisando las rutas académicas principales.</p>
      </div>
      <div class="catalog-back-actions__buttons">
        <a class="ds-button" href="/">Ir a la portada</a>
        <a class="ds-button secondary" href="/#academico">Ver sección académica</a>
      </div>
    </section>
  </main>
</BaseLayout>
