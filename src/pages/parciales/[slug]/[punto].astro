---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { readFile } from "node:fs/promises";
import { join, normalize, relative, resolve, sep } from "node:path";
import { parciales } from "../../../parciales/parciales";

export function getStaticPaths() {
  return parciales
    .flatMap((parcial) =>
      parcial.puntos
        .filter((punto) => parcial.slug === "proyecto-final" || punto.rutaCodigo)
        .map((punto) => ({
          params: { slug: parcial.slug, punto: punto.slug },
          props: { parcial, punto },
        }))
    );
}

const { parcial, punto } = Astro.props;
const esProyectoFinal = parcial.slug === "proyecto-final";
const esFifo1 = esProyectoFinal && punto.slug === "fifo-1";
const esPlaceholderProyectoFinal = esProyectoFinal && !esFifo1;

async function leerArchivoPublico(rutaPublica: string, contexto: string) {
  const rutaRelativa = normalize(rutaPublica.replace(/^\/+/, ""));
  const basePublica = resolve(process.cwd(), "public");
  const absoluta = resolve(basePublica, rutaRelativa);
  const rutaDesdePublic = relative(basePublica, absoluta);
  const esFueraDePublic = rutaDesdePublic.startsWith("..") || rutaDesdePublic.includes(`..${sep}`);

  if (esFueraDePublic) {
    throw new Error(`[parciales] Ruta invalida fuera de public para ${contexto}: ${rutaPublica}`);
  }

  try {
    return await readFile(absoluta, "utf-8");
  } catch (error) {
    const detalle = error instanceof Error ? error.message : String(error);
    throw new Error(`[parciales] No se pudo leer ${contexto} en ${join("public", rutaRelativa)}: ${detalle}`);
  }
}

const codigoPlantilla = punto.rutaCodigo ? await leerArchivoPublico(punto.rutaCodigo, `${parcial.slug}/${punto.slug}`) : null;
const turnosIniciales = [
  { codigo: "A001", nombre: "Laura Diaz" },
  { codigo: "A002", nombre: "Carlos Mejia" },
  { codigo: "A003", nombre: "Sofia Rojas" },
];
const codigoJavaFifo1 = `public class ColaTurnosBanco {
  private Nodo frente;
  private Nodo fin;
  private int size;

  private static class Nodo {
    String codigo;
    String nombre;
    Nodo next;

    Nodo(String codigo, String nombre) {
      this.codigo = codigo;
      this.nombre = nombre;
    }
  }

  public void encolar(String codigo, String nombre) {
    Nodo nuevo = new Nodo(codigo, nombre);

    if (estaVacia()) {
      frente = nuevo;
      fin = nuevo;
    } else {
      fin.next = nuevo;
      fin = nuevo;
    }

    size++;
  }

  public String desencolar() {
    if (estaVacia()) {
      return null;
    }

    Nodo atendido = frente;
    frente = frente.next;

    if (frente == null) {
      fin = null;
    }

    size--;
    return atendido.codigo + " - " + atendido.nombre;
  }

  public String verFrente() {
    return estaVacia() ? null : frente.codigo + " - " + frente.nombre;
  }

  public boolean estaVacia() {
    return frente == null;
  }
}`;
---

<BaseLayout title={`${punto.nombre} | ${parcial.titulo}`}>
  {esFifo1 ? (
    <main class="fifo-shell" id="contenido-principal">
      <section class="fifo-hero">
        <div class="fifo-hero__copy">
          <div class="fifo-hero__eyebrow-row">
            <p class="ds-eyebrow">Proyecto final · Aplicativo disponible</p>
            <span class="fifo-chip">Turnero bancario</span>
          </div>
          <h1>{punto.nombre}</h1>
          <p class="fifo-hero__lead">
            Sistema web de turnos bancarios que aplica una cola FIFO para atender clientes exactamente en el orden en el que llegan,
            mostrando tanto el flujo de negocio como la referencia interna entre nodos.
          </p>
          <div class="fifo-hero__story">
            <div>
              <span>Regla central</span>
              <strong>First In, First Out</strong>
            </div>
            <div>
              <span>Lógica</span>
              <strong>`front`, `rear` y `next`</strong>
            </div>
            <div>
              <span>Complejidad base</span>
              <strong>`enqueue` y `dequeue` en O(1)</strong>
            </div>
          </div>
          <div class="fifo-hero__actions">
            <a class="btn btn-primary" href="#demo-fifo">Probar demo</a>
            <a class="btn btn-secondary" href="#fifo-structure-lab">Ver estructura interna</a>
            <a class="btn btn-ghost" href={`/parciales/${parcial.slug}`}>Volver al catálogo</a>
          </div>
        </div>

        <div class="fifo-hero__panel ds-panel">
          <div class="hero-kpis">
            <article>
              <span>Estructura</span>
              <strong>FIFO</strong>
            </article>
            <article>
              <span>Contexto</span>
              <strong>Atención bancaria</strong>
            </article>
            <article>
              <span>Stack lógico</span>
              <strong>Java</strong>
            </article>
          </div>
          <div class="turno-preview" aria-label="Vista previa de turnos">
            {turnosIniciales.map((turno, index) => (
              <div class={`turno-preview__item ${index === 0 ? "turno-preview__item--front" : ""}`}>
                <span>{turno.codigo}</span>
                <strong>{turno.nombre}</strong>
                <small>{index === 0 ? "Front" : index === turnosIniciales.length - 1 ? "Rear" : "Nodo intermedio"}</small>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="fifo-grid-info">
        <article class="ds-panel fifo-info-card">
          <p class="ds-eyebrow">Problema bancario</p>
          <h2>Orden y trazabilidad en cajas</h2>
          <p>
            En un banco, cada cliente espera que el sistema respete su llegada. Una cola FIFO permite registrar turnos,
            mantener el frente visible y garantizar una atencion justa sin saltos manuales.
          </p>
          <ul class="fifo-bullet-list">
            <li>Evita saltos en el orden de atención.</li>
            <li>Permite mostrar el siguiente cliente con claridad.</li>
            <li>Facilita auditoría básica del flujo de servicio.</li>
          </ul>
        </article>

        <article class="ds-panel fifo-info-card">
          <p class="ds-eyebrow">Qué significa FIFO</p>
          <h2>Primero en entrar, primero en salir</h2>
          <p>
            Cada turno nuevo entra al final de la estructura. Cuando una caja queda disponible, siempre se atiende el nodo que
            se encuentra en el frente. Por eso FIFO representa exactamente el comportamiento esperado en una fila de atención.
          </p>
          <div class="fifo-mini-flow" aria-label="Resumen de la regla FIFO">
            <span>Llega cliente</span>
            <strong>enqueue</strong>
            <span>Queda al final</span>
            <strong>dequeue</strong>
            <span>Sale el frente</span>
          </div>
        </article>
      </section>

      <section class="fifo-flow ds-panel">
        <div>
          <p class="ds-eyebrow">Estructura interna</p>
          <h2>Qué guarda la cola y cómo se conecta</h2>
          <p>
            Esta implementación usa nodos enlazados. Cada nodo conoce al siguiente mediante `next`, mientras que la cola conserva
            referencias directas a `front` y `rear` para operar en tiempo constante.
          </p>
        </div>
        <div class="fifo-flow__steps">
          <article>
            <span>Nodo</span>
            <h3>Datos por cliente</h3>
            <p>Cada nodo almacena el `codigo`, el `nombre` y una referencia `next` hacia el nodo siguiente.</p>
          </article>
          <article>
            <span>Front</span>
            <h3>Inicio de la cola</h3>
            <p>`front` apunta al primer nodo y define quién debe ser atendido cuando se ejecuta `dequeue`.</p>
          </article>
          <article>
            <span>Rear</span>
            <h3>Fin de la cola</h3>
            <p>`rear` apunta al último nodo. Cuando llega un cliente nuevo, `rear.next` enlaza el nodo y luego `rear` avanza.</p>
          </article>
        </div>
        <div class="fifo-ops-grid">
          <article class="fifo-op-card">
            <h3>`enqueue(codigo, nombre)`</h3>
            <p>Crea un nodo nuevo, lo enlaza al final y actualiza `rear`. Si la cola está vacía, `front` y `rear` apuntan al mismo nodo.</p>
            <strong>Complejidad: O(1)</strong>
          </article>
          <article class="fifo-op-card">
            <h3>`dequeue()`</h3>
            <p>Extrae el nodo del frente y mueve `front` al siguiente. Si no quedan nodos, `rear` pasa a `null`.</p>
            <strong>Complejidad: O(1)</strong>
          </article>
          <article class="fifo-op-card">
            <h3>`peek()` y `isEmpty()`</h3>
            <p>Permiten consultar el frente actual o validar si la cola está vacía sin recorrer toda la estructura.</p>
            <strong>Complejidad: O(1)</strong>
          </article>
        </div>
      </section>

      <section class="fifo-demo ds-panel" id="demo-fifo">
        <div class="fifo-demo__head">
          <div>
            <p class="ds-eyebrow">Demo interactiva</p>
            <h2>Simulación del turnero bancario</h2>
            <p>Agrega clientes, atiende el siguiente turno y observa cómo la cola respeta FIFO tanto en el tablero operativo como en la estructura enlazada.</p>
          </div>
          <div class="fifo-demo__actions">
            <button class="btn btn-primary" id="fifo-add" type="button">Agregar turno</button>
            <button class="btn btn-secondary" id="fifo-next" type="button">Atender siguiente</button>
            <button class="btn btn-ghost" id="fifo-reset" type="button">Reiniciar</button>
          </div>
        </div>

        <div class="fifo-form">
          <label for="fifo-name">Nombre del cliente</label>
          <input id="fifo-name" name="fifo-name" type="text" placeholder="Ej. Mariana Torres" autocomplete="off" />
          <p id="fifo-feedback" class="fifo-feedback" aria-live="polite">La cola inicia con tres turnos de ejemplo para mostrar el comportamiento base.</p>
        </div>

        <div class="fifo-dashboard">
          <article>
            <span>Turno en atención</span>
            <strong id="fifo-current">A001 · Laura Diaz</strong>
          </article>
          <article>
            <span>En espera</span>
            <strong id="fifo-count">3 clientes</strong>
          </article>
          <article>
            <span>Último atendido</span>
            <strong id="fifo-last">Aun no hay registros</strong>
          </article>
          <article>
            <span>Front</span>
            <strong id="fifo-front">A001</strong>
          </article>
          <article>
            <span>Rear</span>
            <strong id="fifo-rear">A003</strong>
          </article>
          <article>
            <span>Tamaño</span>
            <strong id="fifo-size">3 nodos</strong>
          </article>
        </div>

        <div class="fifo-op-state">
          <article>
            <span>Operación actual</span>
            <strong id="fifo-op-name">Estado inicial</strong>
          </article>
          <article>
            <span>Explicación</span>
            <p id="fifo-op-detail">`front` apunta a A001, `rear` apunta a A003 y cada nodo intermedio conserva la referencia `next` hacia el siguiente.</p>
          </article>
          <article>
            <span>Bloques Java activos</span>
            <p id="fifo-op-code">queue-fields, enqueue-link y dequeue-front.</p>
          </article>
        </div>

        <div class="fifo-demo__content fifo-demo__content--wide">
          <div class="fifo-queue-panel">
            <div class="fifo-section-head">
              <h3>Cola actual</h3>
              <span>Vista de negocio del turno</span>
            </div>
            <div class="fifo-queue" id="fifo-queue" aria-live="polite"></div>
          </div>

          <div class="fifo-queue-panel fifo-queue-panel--structure" id="fifo-structure-lab">
            <div class="fifo-section-head">
              <h3>Estructura enlazada</h3>
              <span>Nodos horizontales con punteros `next`</span>
            </div>
            <div class="fifo-structure-wrap">
              <div class="fifo-structure" id="fifo-structure" aria-live="polite"></div>
            </div>
          </div>

          <div class="fifo-history-panel">
            <div class="fifo-section-head">
              <h3>Historial de atención</h3>
              <span>Salida en orden de servicio</span>
            </div>
            <ul id="fifo-history" class="fifo-history"></ul>

            <div class="fifo-trace-block">
              <div class="fifo-section-head fifo-section-head--stacked">
                <h3>Bitácora de punteros</h3>
                <span>Cambios recientes en `front`, `rear` y `next`</span>
              </div>
              <ul id="fifo-trace" class="fifo-trace"></ul>
            </div>
          </div>
        </div>
      </section>

      <section class="ds-panel zona-codigo zona-codigo--java">
        <div class="encabezado-cuadro">
          <h2><img src="/icons/rocket.svg" alt="" class="ui-icon" aria-hidden="true" />Lógica Java de la cola</h2>
          <span class="codigo-badge">Referencia conceptual</span>
        </div>
        <div class="fifo-java-grid">
          <article class="fifo-java-note">
            <h3>Clase `Nodo`</h3>
            <p>Representa una unidad de la cola. Guarda los datos del cliente y la referencia `next` al siguiente nodo.</p>
          </article>
          <article class="fifo-java-note">
            <h3>Clase `ColaTurnosBanco`</h3>
            <p>Conserva `front`, `rear` y `size` para resolver las operaciones sin recorrer toda la lista.</p>
          </article>
          <article class="fifo-java-note">
            <h3>Relación con la demo</h3>
            <p>Cada vez que agregas o atiendes un turno, el simulador visual reproduce exactamente las asignaciones del código Java.</p>
          </article>
        </div>
        <div class="fifo-code-view" id="fifo-code-view" aria-label="Bloques de código Java">
          <div class="fifo-code-block" data-code-block="queue-fields">
            <div class="fifo-code-title">Atributos de la cola</div>
            <span class="fifo-code-line">private Nodo frente;</span>
            <span class="fifo-code-line">private Nodo fin;</span>
            <span class="fifo-code-line">private int size;</span>
          </div>

          <div class="fifo-code-block" data-code-block="node-class">
            <div class="fifo-code-title">Clase Nodo</div>
            <span class="fifo-code-line">private static class Nodo {'{'}</span>
            <span class="fifo-code-line">  String codigo;</span>
            <span class="fifo-code-line">  String nombre;</span>
            <span class="fifo-code-line">  Nodo next;</span>
            <span class="fifo-code-line">{'}'}</span>
          </div>

          <div class="fifo-code-block" data-code-block="enqueue-create">
            <div class="fifo-code-title">enqueue: crear nodo</div>
            <span class="fifo-code-line">Nodo nuevo = new Nodo(codigo, nombre);</span>
          </div>

          <div class="fifo-code-block" data-code-block="enqueue-empty">
            <div class="fifo-code-title">enqueue: cola vacía</div>
            <span class="fifo-code-line">if (estaVacia()) {'{'}</span>
            <span class="fifo-code-line">  frente = nuevo;</span>
            <span class="fifo-code-line">  fin = nuevo;</span>
            <span class="fifo-code-line">{'}'}</span>
          </div>

          <div class="fifo-code-block" data-code-block="enqueue-link">
            <div class="fifo-code-title">enqueue: enlazar al final</div>
            <span class="fifo-code-line">fin.next = nuevo;</span>
            <span class="fifo-code-line">fin = nuevo;</span>
          </div>

          <div class="fifo-code-block" data-code-block="enqueue-size">
            <div class="fifo-code-title">enqueue: actualizar tamaño</div>
            <span class="fifo-code-line">size++;</span>
          </div>

          <div class="fifo-code-block" data-code-block="dequeue-guard">
            <div class="fifo-code-title">dequeue: protección</div>
            <span class="fifo-code-line">if (estaVacia()) {'{'}</span>
            <span class="fifo-code-line">  return null;</span>
            <span class="fifo-code-line">{'}'}</span>
          </div>

          <div class="fifo-code-block" data-code-block="dequeue-front">
            <div class="fifo-code-title">dequeue: avanzar frente</div>
            <span class="fifo-code-line">Nodo atendido = frente;</span>
            <span class="fifo-code-line">frente = frente.next;</span>
          </div>

          <div class="fifo-code-block" data-code-block="dequeue-empty-tail">
            <div class="fifo-code-title">dequeue: cola queda vacía</div>
            <span class="fifo-code-line">if (frente == null) {'{'}</span>
            <span class="fifo-code-line">  fin = null;</span>
            <span class="fifo-code-line">{'}'}</span>
          </div>

          <div class="fifo-code-block" data-code-block="dequeue-size">
            <div class="fifo-code-title">dequeue: actualizar tamaño</div>
            <span class="fifo-code-line">size--;</span>
          </div>

          <div class="fifo-code-block" data-code-block="peek">
            <div class="fifo-code-title">peek / verFrente</div>
            <span class="fifo-code-line">return estaVacia() ? null : frente.codigo + " - " + frente.nombre;</span>
          </div>

          <div class="fifo-code-block" data-code-block="is-empty">
            <div class="fifo-code-title">isEmpty</div>
            <span class="fifo-code-line">return frente == null;</span>
          </div>
        </div>
      </section>
    </main>
  ) : esPlaceholderProyectoFinal ? (
    <main class="placeholder-shell" id="contenido-principal">
      <section class="program-hero">
        <img src="/programas-temporales/uis-logo.svg" alt="Logotipo de la Universidad Industrial de Santander" loading="eager" decoding="async" />
        <div>
          <p class="ds-eyebrow">{parcial.titulo}</p>
          <h1>{punto.nombre}</h1>
          <p>{punto.descripcion}</p>
        </div>
        <a class="icono-volver" href={`/parciales/${parcial.slug}`} aria-label="Volver al catálogo de aplicativos" title="Volver al catálogo de aplicativos">
          <img src="/icons/folder.svg" alt="" class="ui-icon" aria-hidden="true" />
        </a>
      </section>

      <section class="ds-panel placeholder-card">
        <span class="placeholder-pill">Próximamente</span>
        <h2>Este aplicativo forma parte del roadmap del proyecto final</h2>
        <p>
          La estructura base ya quedó preparada para recibir esta nueva experiencia. Cuando se implemente,
          conservará el mismo patrón de navegación, detalle y demo usado en FIFO 1.
        </p>
        <div class="placeholder-actions">
          <a class="btn btn-primary" href={`/parciales/${parcial.slug}`}>Volver al catálogo</a>
          <a class="btn btn-ghost" href={`/parciales/${parcial.slug}/fifo-1`}>Ver FIFO 1</a>
        </div>
      </section>
    </main>
  ) : (
    <main class="programa-shell" id="contenido-principal">
      <section class="program-hero">
        <img src="/programas-temporales/uis-logo.svg" alt="Logotipo de la Universidad Industrial de Santander" loading="eager" decoding="async" />
        <div>
          <p class="ds-eyebrow">{parcial.titulo}</p>
          <h1>{punto.nombre}</h1>
          <p>{punto.descripcion}</p>
        </div>
        <a class="icono-volver" href={`/parciales/${parcial.slug}`} aria-label="Volver al listado de puntos" title="Volver al listado de puntos">
          <img src="/icons/folder.svg" alt="" class="ui-icon" aria-hidden="true" />
        </a>
      </section>

      {codigoPlantilla && (
        <section class="ds-panel zona-codigo">
          <div class="encabezado-cuadro">
            <h2><img src="/icons/rocket.svg" alt="" class="ui-icon" aria-hidden="true" />Código del punto</h2>
            {parcial.slug === "parcial-01" && (
              <button class="boton-copiar" type="button" aria-label="Copiar codigo">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                  <path d="M8 7a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-9a2 2 0 0 1-2-2V7Zm2 0h9v11h-9V7Z" />
                  <path d="M5 4a2 2 0 0 1 2-2h9v2H7v11H5V4Zm-2 5h2v11a2 2 0 0 0 2 2h11v2H7a2 2 0 0 1-2-2V9Z" />
                </svg>
              </button>
            )}
          </div>
          <pre class="cuadro-codigo"><code>{codigoPlantilla}</code></pre>
        </section>
      )}

      {punto.rutaImagen && (
        <section class="ds-panel zona-imagen">
          <h2><img src="/icons/flask.svg" alt="" class="ui-icon" aria-hidden="true" />Output del punto</h2>
          <div class="marco-imagen">
            <img
              src={punto.rutaImagen}
              alt={`Imagen de salida de ${punto.nombre}`}
              loading="lazy"
              decoding="async"
            />
          </div>
        </section>
      )}
    </main>
  )}

  <script is:inline define:vars={{ turnosIniciales }}>
    const botonCopiar = document.querySelector(".boton-copiar");
    const nodoCodigo = document.querySelector(".cuadro-codigo");

    botonCopiar?.addEventListener("click", async () => {
      if (!nodoCodigo) return;

      const texto = nodoCodigo.textContent ?? "";
      const iconoOriginal = botonCopiar?.querySelector("svg")?.cloneNode(true);

      try {
        await navigator.clipboard.writeText(texto);
        botonCopiar.textContent = "✅";
        setTimeout(() => {
          botonCopiar?.replaceChildren();
          if (iconoOriginal) {
            botonCopiar?.appendChild(iconoOriginal.cloneNode(true));
          }
        }, 1400);
      } catch {
        const seleccion = window.getSelection();
        const rango = document.createRange();
        rango.selectNodeContents(nodoCodigo);
        seleccion?.removeAllRanges();
        seleccion?.addRange(rango);
      }
    });

    const queueRoot = document.querySelector("#fifo-queue");
    if (queueRoot) {
      const historyRoot = document.querySelector("#fifo-history");
      const structureRoot = document.querySelector("#fifo-structure");
      const traceRoot = document.querySelector("#fifo-trace");
      const feedbackNode = document.querySelector("#fifo-feedback");
      const inputNode = document.querySelector("#fifo-name");
      const currentNode = document.querySelector("#fifo-current");
      const countNode = document.querySelector("#fifo-count");
      const lastNode = document.querySelector("#fifo-last");
      const frontNode = document.querySelector("#fifo-front");
      const rearNode = document.querySelector("#fifo-rear");
      const sizeNode = document.querySelector("#fifo-size");
      const opNameNode = document.querySelector("#fifo-op-name");
      const opDetailNode = document.querySelector("#fifo-op-detail");
      const opCodeNode = document.querySelector("#fifo-op-code");
      const addButton = document.querySelector("#fifo-add");
      const nextButton = document.querySelector("#fifo-next");
      const resetButton = document.querySelector("#fifo-reset");
      const codeBlocks = Array.from(document.querySelectorAll("[data-code-block]"));
      const metricNodes = {
        current: currentNode?.closest("article") ?? null,
        count: countNode?.closest("article") ?? null,
        last: lastNode?.closest("article") ?? null,
        front: frontNode?.closest("article") ?? null,
        rear: rearNode?.closest("article") ?? null,
        size: sizeNode?.closest("article") ?? null,
      };

      const initialQueue = turnosIniciales.map((turno) => ({ ...turno }));
      let queue = initialQueue.map((turno) => ({ ...turno }));
      let history = [];
      let trace = [
        "Estado inicial: front = A001, rear = A003 y A001.next apunta a A002.",
        "Los nodos intermedios mantienen el enlace next hasta llegar al final de la cola.",
      ];
      let nextId = initialQueue.length + 1;
      let operationTitle = "Estado inicial";
      let operationDetail = "La cola comienza con tres nodos enlazados. `front` apunta a A001 y `rear` apunta a A003.";
      let operationCode = "queue-fields, node-class y enqueue-link.";
      let activeCodeBlocks = ["queue-fields", "node-class", "enqueue-link"];
      let animationState = {
        type: "idle",
        phase: "complete",
        focusCode: null,
        frontCode: queue[0]?.codigo ?? null,
        rearCode: queue[queue.length - 1]?.codigo ?? null,
        activeArrowFrom: null,
        exitingCode: null,
        incomingCode: null,
        metricKeys: ["front", "rear", "size"],
      };
      let animationStepTimeouts = [];

      const formatoTurno = (turno) => `${turno.codigo} · ${turno.nombre}`;
      const formatoRef = (turno) => (turno ? turno.codigo : "null");

      const registrarTrazas = (...lineas) => {
        trace = [...lineas, ...trace].slice(0, 7);
      };

      const clearAnimationTimers = () => {
        animationStepTimeouts.forEach((timer) => window.clearTimeout(timer));
        animationStepTimeouts = [];
      };

      const setCodeHighlights = (blocks = []) => {
        activeCodeBlocks = blocks;
        codeBlocks.forEach((block) => {
          const key = block.getAttribute("data-code-block") ?? "";
          const stateIndex = blocks.indexOf(key);
          block.classList.toggle("fifo-code-block--active", stateIndex === 0);
          block.classList.toggle("fifo-code-block--related", stateIndex > 0);
        });
      };

      const setAnimationState = (state = {}) => {
        animationState = {
          type: state.type ?? animationState.type,
          phase: state.phase ?? animationState.phase,
          focusCode: state.focusCode ?? null,
          frontCode: state.frontCode ?? queue[0]?.codigo ?? null,
          rearCode: state.rearCode ?? queue[queue.length - 1]?.codigo ?? null,
          activeArrowFrom: state.activeArrowFrom ?? null,
          exitingCode: state.exitingCode ?? null,
          incomingCode: state.incomingCode ?? null,
          metricKeys: state.metricKeys ?? [],
        };
        if (state.codeBlocks) {
          setCodeHighlights(state.codeBlocks);
        }
        render();
      };

      const runSequence = (steps) => {
        clearAnimationTimers();
        let delay = 0;
        for (const step of steps) {
          const timer = window.setTimeout(() => {
            if (step.operationTitle) operationTitle = step.operationTitle;
            if (step.operationDetail) operationDetail = step.operationDetail;
            if (step.operationCode) operationCode = step.operationCode;
            setAnimationState(step.animationState ?? {});
          }, delay);
          animationStepTimeouts.push(timer);
          delay += step.duration ?? 220;
        }
      };

      const render = () => {
        if (currentNode) {
          currentNode.textContent = queue[0] ? formatoTurno(queue[0]) : "Sin clientes en espera";
        }

        if (countNode) {
          const total = queue.length;
          countNode.textContent = `${total} ${total === 1 ? "cliente" : "clientes"}`;
        }

        if (lastNode) {
          lastNode.textContent = history[0] ? formatoTurno(history[0]) : "Aun no hay registros";
        }

        if (frontNode) {
          frontNode.textContent = formatoRef(queue[0]);
        }

        if (rearNode) {
          rearNode.textContent = formatoRef(queue[queue.length - 1]);
        }

        if (sizeNode) {
          sizeNode.textContent = `${queue.length} ${queue.length === 1 ? "nodo" : "nodos"}`;
        }

        if (opNameNode) {
          opNameNode.textContent = operationTitle;
        }

        if (opDetailNode) {
          opDetailNode.textContent = operationDetail;
        }

        if (opCodeNode) {
          opCodeNode.textContent = operationCode;
        }

        Object.entries(metricNodes).forEach(([key, article]) => {
          article?.classList.toggle("fifo-metric--active", animationState.metricKeys.includes(key));
        });

        queueRoot.replaceChildren();

        if (queue.length === 0) {
          const empty = document.createElement("div");
          empty.className = "fifo-queue__empty";
          empty.textContent = "La cola está vacía. Agrega un nuevo turno para continuar la simulación.";
          queueRoot.appendChild(empty);
        } else {
          queue.forEach((turno, index) => {
            const card = document.createElement("article");
            const clases = ["fifo-turno"];
            if (index === 0) clases.push("fifo-turno--front");
            if (animationState.focusCode === turno.codigo) clases.push("fifo-turno--focus");
            if (animationState.incomingCode === turno.codigo) clases.push("fifo-turno--anim-enter");
            if (animationState.exitingCode === turno.codigo) clases.push("fifo-turno--anim-exit");
            card.className = clases.join(" ");
            card.innerHTML = `<span>${index === 0 ? "En frente" : `Posición ${index + 1}`}</span><strong>${turno.codigo}</strong><p>${turno.nombre}</p>`;
            queueRoot.appendChild(card);
          });
        }

        structureRoot?.replaceChildren();

        if (queue.length === 0) {
          const emptyStructure = document.createElement("div");
          emptyStructure.className = "fifo-structure-empty";
          emptyStructure.innerHTML = "<strong>Front = null</strong><span>Rear = null</span><p>No existen nodos enlazados en este momento.</p>";
          structureRoot?.appendChild(emptyStructure);
        } else {
          queue.forEach((turno, index) => {
            const piece = document.createElement("div");
            piece.className = "fifo-structure-piece";

            const pointerTop = [];
            if (index === 0) pointerTop.push(`<span class="fifo-pointer fifo-pointer--front ${animationState.frontCode === turno.codigo ? "fifo-pointer--active" : ""}">Front</span>`);
            if (index === queue.length - 1) pointerTop.push(`<span class="fifo-pointer fifo-pointer--rear ${animationState.rearCode === turno.codigo ? "fifo-pointer--active" : ""}">Rear</span>`);

            const nodeClasses = ["fifo-node"];
            if (index === 0) nodeClasses.push("fifo-node--front");
            if (index === queue.length - 1) nodeClasses.push("fifo-node--rear");
            if (animationState.focusCode === turno.codigo) nodeClasses.push("fifo-node--focus");
            if (animationState.incomingCode === turno.codigo) nodeClasses.push("fifo-node--incoming");
            if (animationState.exitingCode === turno.codigo) nodeClasses.push("fifo-node--outgoing");
            if (animationState.frontCode === turno.codigo) nodeClasses.push("fifo-node--front-active");
            if (animationState.rearCode === turno.codigo) nodeClasses.push("fifo-node--rear-active");

            piece.innerHTML = `
              <div class="fifo-pointer-row">${pointerTop.join("")}</div>
              <article class="${nodeClasses.join(" ")}">
                <span class="fifo-node__label">Nodo ${index + 1}</span>
                <strong>${turno.codigo}</strong>
                <p>${turno.nombre}</p>
                <small>next: ${queue[index + 1] ? queue[index + 1].codigo : "null"}</small>
              </article>
            `;

            structureRoot?.appendChild(piece);

            if (index < queue.length - 1) {
              const arrow = document.createElement("div");
              arrow.className = `fifo-arrow ${animationState.activeArrowFrom === turno.codigo ? "fifo-arrow--active" : ""}`;
              arrow.innerHTML = '<span>next</span><strong>→</strong>';
              structureRoot?.appendChild(arrow);
            } else {
              const nullArrow = document.createElement("div");
              nullArrow.className = `fifo-arrow fifo-arrow--null ${animationState.activeArrowFrom === turno.codigo ? "fifo-arrow--active" : ""}`;
              nullArrow.innerHTML = '<span>next</span><strong>null</strong>';
              structureRoot?.appendChild(nullArrow);
            }
          });
        }

        historyRoot?.replaceChildren();

        if (history.length === 0) {
          const item = document.createElement("li");
          item.className = "fifo-history__empty";
          item.textContent = "Todavía no se ha atendido ningún cliente.";
          historyRoot?.appendChild(item);
        } else {
          history.forEach((turno) => {
            const item = document.createElement("li");
            item.textContent = formatoTurno(turno);
            historyRoot?.appendChild(item);
          });
        }

        traceRoot?.replaceChildren();
        trace.forEach((linea) => {
          const item = document.createElement("li");
          item.textContent = linea;
          traceRoot?.appendChild(item);
        });
      };

      addButton?.addEventListener("click", () => {
        const nombre = inputNode instanceof HTMLInputElement ? inputNode.value.trim() : "";
        if (!nombre) {
          if (feedbackNode) {
            feedbackNode.textContent = "Ingresa el nombre del cliente antes de generar un nuevo turno.";
          }
          inputNode?.focus();
          return;
        }

        const codigo = `A${String(nextId).padStart(3, "0")}`;
        const previousRear = queue[queue.length - 1] ?? null;
        nextId += 1;
        queue.push({ codigo, nombre });
        if (previousRear) {
          registrarTrazas(
            `enqueue(${codigo}, ${nombre})`,
            `Se crea el nodo ${codigo}`,
            `${previousRear.codigo}.next = ${codigo}`,
            `rear = ${codigo}`,
            `size = ${queue.length}`
          );
          runSequence([
            {
              operationTitle: `enqueue(${codigo}, ${nombre})`,
              operationDetail: `Se crea el nodo ${codigo} para ${nombre}, pero todavía no está enlazado al final de la cola.`,
              operationCode: "Bloque activo: enqueue-create.",
              animationState: {
                type: "enqueue",
                phase: "start",
                focusCode: codigo,
                incomingCode: codigo,
                rearCode: previousRear.codigo,
                metricKeys: ["rear", "size"],
                codeBlocks: ["enqueue-create", "node-class"],
              },
              duration: 180,
            },
            {
              operationDetail: `Ahora ${previousRear.codigo}.next apunta a ${codigo} y el puntero rear se prepara para avanzar.`,
              operationCode: "Bloques activos: enqueue-link y queue-fields.",
              animationState: {
                type: "enqueue",
                phase: "link",
                focusCode: codigo,
                incomingCode: codigo,
                rearCode: codigo,
                activeArrowFrom: previousRear.codigo,
                metricKeys: ["rear"],
                codeBlocks: ["enqueue-link", "queue-fields"],
              },
              duration: 280,
            },
            {
              operationDetail: `La operación termina con rear = ${codigo} y size = ${queue.length}. La cola mantiene FIFO intacto.`,
              operationCode: "Bloques activos: enqueue-size, enqueue-link y queue-fields.",
              animationState: {
                type: "enqueue",
                phase: "complete",
                focusCode: codigo,
                rearCode: codigo,
                metricKeys: ["rear", "size", "count"],
                codeBlocks: ["enqueue-size", "enqueue-link", "queue-fields"],
              },
              duration: 220,
            },
          ]);
        } else {
          registrarTrazas(
            `enqueue(${codigo}, ${nombre})`,
            `Se crea el nodo ${codigo}`,
            `front = ${codigo}`,
            `rear = ${codigo}`,
            `size = ${queue.length}`
          );
          runSequence([
            {
              operationTitle: `enqueue(${codigo}, ${nombre})`,
              operationDetail: `Se crea el nodo ${codigo} para ${nombre} sobre una cola vacía.`,
              operationCode: "Bloques activos: enqueue-create y node-class.",
              animationState: {
                type: "enqueue",
                phase: "start",
                focusCode: codigo,
                incomingCode: codigo,
                metricKeys: ["front", "rear", "size"],
                codeBlocks: ["enqueue-create", "node-class"],
              },
              duration: 180,
            },
            {
              operationDetail: `Como no había nodos, ${codigo} pasa a ser simultáneamente front y rear.`,
              operationCode: "Bloques activos: enqueue-empty y queue-fields.",
              animationState: {
                type: "enqueue",
                phase: "link",
                focusCode: codigo,
                incomingCode: codigo,
                frontCode: codigo,
                rearCode: codigo,
                metricKeys: ["front", "rear"],
                codeBlocks: ["enqueue-empty", "queue-fields"],
              },
              duration: 280,
            },
            {
              operationDetail: `La cola queda inicializada con un solo nodo y size = 1.`,
              operationCode: "Bloques activos: enqueue-size, enqueue-empty y queue-fields.",
              animationState: {
                type: "enqueue",
                phase: "complete",
                focusCode: codigo,
                frontCode: codigo,
                rearCode: codigo,
                metricKeys: ["front", "rear", "size", "count"],
                codeBlocks: ["enqueue-size", "enqueue-empty", "queue-fields"],
              },
              duration: 220,
            },
          ]);
        }
        if (feedbackNode) {
          feedbackNode.textContent = `Se agregó ${codigo} para ${nombre} al final de la cola.`;
        }
        if (inputNode instanceof HTMLInputElement) {
          inputNode.value = "";
          inputNode.focus();
        }
      });

      nextButton?.addEventListener("click", () => {
        if (queue.length === 0) {
          operationTitle = "dequeue() sobre cola vacía";
          operationDetail = "No se puede atender un cliente porque front y rear ya están en null.";
          operationCode = "Bloques activos: dequeue-guard e is-empty.";
          registrarTrazas("dequeue() abortado", "La cola está vacía: front = null, rear = null");
          if (feedbackNode) {
            feedbackNode.textContent = "No hay clientes en espera. Agrega un nuevo turno para continuar.";
          }
          runSequence([
            {
              animationState: {
                type: "empty",
                phase: "start",
                metricKeys: ["front", "rear"],
                codeBlocks: ["dequeue-guard", "is-empty"],
              },
              duration: 260,
            },
          ]);
          return;
        }

        const atendido = queue[0];
        const previousRear = queue[queue.length - 1];
        const nextFront = queue[1] ?? null;
        const queueWillBeEmpty = queue.length === 1;
        history.unshift(atendido);
        queue = queue.slice(1);

        registrarTrazas(
          `dequeue() -> ${atendido.codigo}`,
          queue[0] ? `front = ${queue[0].codigo}` : "front = null",
          queueWillBeEmpty ? "rear = null" : `rear = ${previousRear.codigo}`,
          `size = ${queue.length}`
        );

        operationTitle = `dequeue() -> ${atendido.codigo}`;
        if (queue[0]) {
          operationDetail = `El nodo ${atendido.codigo} abandona el frente. El nuevo front será ${queue[0].codigo} y rear permanece en ${previousRear.codigo}.`;
          operationCode = "Bloques activos: dequeue-front y queue-fields.";
        } else {
          operationDetail = `El nodo ${atendido.codigo} era el único elemento, por eso después de atenderlo front y rear quedan en null.`;
          operationCode = "Bloques activos: dequeue-empty-tail y dequeue-front.";
        }

        if (feedbackNode) {
          feedbackNode.textContent = `${atendido.codigo} de ${atendido.nombre} fue atendido correctamente.`;
        }

        if (queueWillBeEmpty) {
          runSequence([
            {
              animationState: {
                type: "dequeue",
                phase: "start",
                focusCode: atendido.codigo,
                exitingCode: atendido.codigo,
                frontCode: atendido.codigo,
                rearCode: atendido.codigo,
                metricKeys: ["front", "rear", "current"],
                codeBlocks: ["dequeue-front", "queue-fields"],
              },
              duration: 180,
            },
            {
              operationDetail: `Tras retirar ${atendido.codigo}, la cola ya no tiene nodos enlazados. front = null y rear = null.`,
              operationCode: "Bloques activos: dequeue-empty-tail, dequeue-front y queue-fields.",
              animationState: {
                type: "dequeue",
                phase: "shift",
                exitingCode: atendido.codigo,
                metricKeys: ["front", "rear", "size", "count"],
                codeBlocks: ["dequeue-empty-tail", "dequeue-front", "queue-fields"],
              },
              duration: 300,
            },
            {
              operationDetail: `La operación termina con size = 0 y la cola lista para recibir un nuevo primer nodo.`,
              operationCode: "Bloques activos: dequeue-size, dequeue-empty-tail y queue-fields.",
              animationState: {
                type: "dequeue",
                phase: "complete",
                metricKeys: ["size", "count"],
                codeBlocks: ["dequeue-size", "dequeue-empty-tail", "queue-fields"],
              },
              duration: 220,
            },
          ]);
        } else {
          runSequence([
            {
              animationState: {
                type: "dequeue",
                phase: "start",
                focusCode: atendido.codigo,
                exitingCode: atendido.codigo,
                frontCode: atendido.codigo,
                rearCode: previousRear.codigo,
                metricKeys: ["front", "current"],
                codeBlocks: ["dequeue-front", "queue-fields"],
              },
              duration: 180,
            },
            {
              operationDetail: `El nodo ${atendido.codigo} se retira y front avanza a ${nextFront.codigo}. El puntero rear no cambia.`,
              operationCode: "Bloques activos: dequeue-front y queue-fields.",
              animationState: {
                type: "dequeue",
                phase: "shift",
                focusCode: nextFront.codigo,
                frontCode: nextFront.codigo,
                rearCode: previousRear.codigo,
                metricKeys: ["front", "rear", "current"],
                codeBlocks: ["dequeue-front", "queue-fields"],
              },
              duration: 300,
            },
            {
              operationDetail: `La cola queda con size = ${queue.length}. FIFO se conserva porque el nuevo frente es el siguiente nodo enlazado.`,
              operationCode: "Bloques activos: dequeue-size, dequeue-front y queue-fields.",
              animationState: {
                type: "dequeue",
                phase: "complete",
                focusCode: nextFront.codigo,
                frontCode: nextFront.codigo,
                rearCode: previousRear.codigo,
                metricKeys: ["front", "rear", "size", "count"],
                codeBlocks: ["dequeue-size", "dequeue-front", "queue-fields"],
              },
              duration: 220,
            },
          ]);
        }
      });

      resetButton?.addEventListener("click", () => {
        clearAnimationTimers();
        queue = initialQueue.map((turno) => ({ ...turno }));
        history = [];
        trace = [
          "Reset: front = A001 y rear = A003 restaurados.",
          "La estructura vuelve a enlazar los turnos iniciales con referencias next consecutivas.",
        ];
        nextId = initialQueue.length + 1;
        operationTitle = "Reset de simulación";
        operationDetail = "La cola volvió a su configuración original con tres nodos enlazados y sin historial de atención.";
        operationCode = "Bloques activos: queue-fields, node-class y enqueue-link.";
        if (inputNode instanceof HTMLInputElement) {
          inputNode.value = "";
        }
        if (feedbackNode) {
          feedbackNode.textContent = "La simulación volvió al estado inicial con los turnos de ejemplo.";
        }
        runSequence([
          {
            animationState: {
              type: "reset",
              phase: "start",
              frontCode: queue[0]?.codigo ?? null,
              rearCode: queue[queue.length - 1]?.codigo ?? null,
              metricKeys: ["front", "rear", "size", "count"],
              codeBlocks: ["queue-fields", "node-class", "enqueue-link"],
            },
            duration: 260,
          },
        ]);
      });

      setCodeHighlights(activeCodeBlocks);
      render();
    }
  </script>
</BaseLayout>

