    color: var(--terra-light);
  }

  .fifo-arrow--active strong,
  .fifo-arrow--active span {
    color: var(--terra-light);
    animation: fifoArrowGlow 380ms ease;
  }

  .fifo-arrow--null strong {
    font-size: 0.9rem;
    padding: 0.45rem 0.65rem;
    border-radius: 999px;
    border: 1px dashed var(--br-2);
    color: var(--text-2);
  }

  .fifo-structure-empty {
    display: grid;
    gap: var(--sp-2);
    padding: var(--sp-5);
    border-radius: 22px;
    border: 1px dashed var(--br-2);
    color: var(--text-2);
  }

