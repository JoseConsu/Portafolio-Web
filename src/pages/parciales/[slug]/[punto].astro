    color: var(--text-2);
  }

  .fifo-history {
    display: grid;
    gap: var(--sp-2);
    margin: var(--sp-4) 0 0;
    padding: 0;
    list-style: none;
  }

  .fifo-history li {
    padding: 0.85rem 1rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-1);
  }

  .fifo-trace-block {
    margin-top: var(--sp-5);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--br-1);
  }

  .fifo-section-head--stacked {
    align-items: flex-start;
  }

  .fifo-trace {
    display: grid;
    gap: var(--sp-2);
    list-style: none;
    padding: 0;
    margin: var(--sp-4) 0 0;
  }

  .fifo-trace li {
    padding: 0.85rem 1rem;
    border-radius: 14px;
    border: 1px solid var(--br-1);
    background: rgba(8, 14, 24, 0.72);
    color: var(--text-2);
    font-family: var(--ff-mono);
    font-size: 0.84rem;
    line-height: 1.6;
  }

  .fifo-java-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
  }

  .fifo-java-intro {
    margin-bottom: var(--sp-4);
    padding: var(--sp-4);
    border-radius: 18px;
    border: 1px solid var(--br-1);
    background: rgba(255, 255, 255, 0.03);
  }

  .fifo-java-intro p {
    color: var(--text-2);
    line-height: 1.75;
  }

  .fifo-code-editor {
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--br-1);
    background: linear-gradient(180deg, rgba(7, 11, 20, 0.98), rgba(11, 18, 32, 0.98));
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
  }

  .fifo-code-editor__bar {
    display: flex;
    gap: 0.45rem;
    align-items: center;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--br-1);
    background: rgba(255, 255, 255, 0.03);
  }

  .fifo-code-editor__bar span {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--text-3);
  }

  .fifo-code-editor__bar span:first-child {
    background: #ff5f57;
  }

  .fifo-code-editor__bar span:nth-child(2) {
    background: #febc2e;
  }

  .fifo-code-editor__bar span:nth-child(3) {
    background: #28c840;
  }

  .fifo-code-view {
    display: grid;
    gap: 0;
    padding: var(--sp-4) 0;
  }

  .fifo-code-block {
    padding: 0.15rem var(--sp-5);
    border-left: 3px solid transparent;
    transition: border-color 180ms ease, background 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .fifo-code-block--active {
    border-left-color: color-mix(in srgb, var(--terra) 70%, transparent);
    background: linear-gradient(90deg, rgba(231, 160, 94, 0.12), transparent 72%);
    animation: fifoCodeGlow 380ms ease;
  }

  .fifo-code-block--related {
    border-left-color: color-mix(in srgb, var(--success) 45%, transparent);
    background: linear-gradient(90deg, rgba(34, 197, 94, 0.08), transparent 72%);
  }

  .fifo-code-line {
    display: block;
    font-family: var(--ff-mono);
    font-size: 0.88rem;
    line-height: 1.72;
    color: #d6dde8;
    white-space: pre-wrap;
  }

  .fifo-code-comment {
    color: #7fb18a;
  }

  @keyframes fifoNodeEnter {
    0% {
      opacity: 0;
      transform: translateX(16px) scale(0.98);
    }

    100% {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  @keyframes fifoNodeExit {
    0% {
      opacity: 1;
      transform: translateX(0) scale(1);
    }

    100% {
      opacity: 0.62;
      transform: translateX(-10px) scale(0.98);
    }
  }

  @keyframes fifoPointerPulse {
    0% {
      transform: scale(1);
    }

    50% {
      transform: scale(1.04);
    }

    100% {
      transform: scale(1);
    }
  }

  @keyframes fifoArrowGlow {
    0% {
      opacity: 0.65;
    }

    50% {
      opacity: 1;
      transform: scale(1.04);
    }

    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes fifoMetricPulse {
    0% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-2px);
    }

    100% {
      transform: translateY(0);
    }
  }

  @keyframes fifoCodeGlow {
    0% {
      opacity: 0.86;
    }

    50% {
      opacity: 1;
    }

    100% {
      opacity: 1;
    }
  }

  .zona-codigo--java .encabezado-cuadro {
