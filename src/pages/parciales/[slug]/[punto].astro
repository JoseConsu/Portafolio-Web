---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { readFile } from "node:fs/promises";
import { join, normalize, relative, resolve, sep } from "node:path";
import { parciales } from "../../../parciales/parciales";

export function getStaticPaths() {
  return parciales
    .flatMap((parcial) =>
      parcial.puntos
        .filter((punto) => parcial.slug === "proyecto-final" || punto.rutaCodigo)
        .map((punto) => ({
          params: { slug: parcial.slug, punto: punto.slug },
          props: { parcial, punto },
        }))
    );
}

const { parcial, punto } = Astro.props;
const esProyectoFinal = parcial.slug === "proyecto-final";
const esFifo1 = esProyectoFinal && punto.slug === "fifo-1";
const esFifo2 = esProyectoFinal && punto.slug === "fifo-2";
const esFilo1 = esProyectoFinal && punto.slug === "filo-1";
const esFilo2 = esProyectoFinal && punto.slug === "filo-2";
const esPlaceholderProyectoFinal = esProyectoFinal && !esFifo1 && !esFifo2 && !esFilo1 && !esFilo2;

async function leerArchivoPublico(rutaPublica: string, contexto: string) {
  const rutaRelativa = normalize(rutaPublica.replace(/^\/+/, ""));
  const basePublica = resolve(process.cwd(), "public");
  const absoluta = resolve(basePublica, rutaRelativa);
  const rutaDesdePublic = relative(basePublica, absoluta);
  const esFueraDePublic = rutaDesdePublic.startsWith("..") || rutaDesdePublic.includes(`..${sep}`);

  if (esFueraDePublic) {
    throw new Error(`[parciales] Ruta invalida fuera de public para ${contexto}: ${rutaPublica}`);
  }

  try {
    return await readFile(absoluta, "utf-8");
  } catch (error) {
    const detalle = error instanceof Error ? error.message : String(error);
    throw new Error(`[parciales] No se pudo leer ${contexto} en ${join("public", rutaRelativa)}: ${detalle}`);
  }
}

const codigoPlantilla = punto.rutaCodigo ? await leerArchivoPublico(punto.rutaCodigo, `${parcial.slug}/${punto.slug}`) : null;
const turnosIniciales = [
  { codigo: "A001", nombre: "Laura Diaz" },
  { codigo: "A002", nombre: "Carlos Mejia" },
  { codigo: "A003", nombre: "Sofia Rojas" },
];
const trabajosImpresionIniciales = [
  { codigo: "P001", nombre: "Informe Q3.pdf", paginas: 12, owner: "cris" },
  { codigo: "P002", nombre: "Contrato Marzo.docx", paginas: 4, owner: "cris" },
  { codigo: "P003", nombre: "Etiquetas envio.xlsx", paginas: 2, owner: "cris" },
];
const accionesFiloIniciales = ["Escribir título", "Insertar imagen", "Cambiar color de fondo"];
---

<BaseLayout title={`${punto.nombre} | ${parcial.titulo}`}>
  {esFifo1 ? (
    <main class="fifo-shell" id="contenido-principal">
      <section class="fifo-hero">
        <div class="fifo-hero__copy">
          <div class="fifo-hero__eyebrow-row">
            <p class="ds-eyebrow">Proyecto final · Aplicativo disponible</p>
            <span class="fifo-chip">Turnero bancario</span>
          </div>
          <h1>{punto.nombre}</h1>
          <p class="fifo-hero__lead">
            Sistema web de turnos bancarios que aplica una cola FIFO para atender clientes exactamente en el orden en el que llegan,
            mostrando tanto el flujo de negocio como la referencia interna entre nodos.
          </p>
          <div class="fifo-hero__story">
            <div>
              <span>Regla central</span>
              <strong>First In, First Out</strong>
            </div>
            <div>
              <span>Lógica</span>
              <strong>`front`, `rear` y `next`</strong>
            </div>
            <div>
              <span>Complejidad base</span>
              <strong>`enqueue` y `dequeue` en O(1)</strong>
            </div>
          </div>
          <div class="fifo-hero__actions">
            <a class="btn btn-primary" href="#demo-fifo">Probar demo</a>
            <a class="btn btn-secondary" href="#fifo-structure-lab">Ver estructura interna</a>
            <a class="btn btn-ghost" href={`/parciales/${parcial.slug}`}>Volver al catálogo</a>
          </div>
        </div>

        <div class="fifo-hero__panel ds-panel">
          <div class="hero-kpis">
            <article>
              <span>Estructura</span>
              <strong>FIFO</strong>
            </article>
            <article>
              <span>Contexto</span>
              <strong>Atención bancaria</strong>
            </article>
            <article>
              <span>Stack lógico</span>
              <strong>Java</strong>
            </article>
          </div>
          <div class="turno-preview" aria-label="Vista previa de turnos">
            {turnosIniciales.map((turno, index) => (
              <div class={`turno-preview__item ${index === 0 ? "turno-preview__item--front" : ""}`}>
                <span>{turno.codigo}</span>
                <strong>{turno.nombre}</strong>
                <small>{index === 0 ? "Front" : index === turnosIniciales.length - 1 ? "Rear" : "Nodo intermedio"}</small>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="fifo-grid-info">
        <article class="ds-panel fifo-info-card">
          <p class="ds-eyebrow">Problema bancario</p>
          <h2>Orden y trazabilidad en cajas</h2>
          <p>
            En un banco, cada cliente espera que el sistema respete su llegada. Una cola FIFO permite registrar turnos,
            mantener el frente visible y garantizar una atencion justa sin saltos manuales.
          </p>
          <ul class="fifo-bullet-list">
            <li>Evita saltos en el orden de atención.</li>
            <li>Permite mostrar el siguiente cliente con claridad.</li>
            <li>Facilita auditoría básica del flujo de servicio.</li>
          </ul>
        </article>

        <article class="ds-panel fifo-info-card">
          <p class="ds-eyebrow">Qué significa FIFO</p>
          <h2>Primero en entrar, primero en salir</h2>
          <p>
            Cada turno nuevo entra al final de la estructura. Cuando una caja queda disponible, siempre se atiende el nodo que
            se encuentra en el frente. Por eso FIFO representa exactamente el comportamiento esperado en una fila de atención.
          </p>
          <div class="fifo-mini-flow" aria-label="Resumen de la regla FIFO">
            <span>Llega cliente</span>
            <strong>enqueue</strong>
            <span>Queda al final</span>
            <strong>dequeue</strong>
            <span>Sale el frente</span>
          </div>
        </article>
      </section>

      <section class="fifo-flow ds-panel">
        <div>
          <p class="ds-eyebrow">Estructura interna</p>
          <h2>Qué guarda la cola y cómo se conecta</h2>
          <p>
            Esta implementación usa nodos enlazados. Cada nodo conoce al siguiente mediante `next`, mientras que la cola conserva
            referencias directas a `front` y `rear` para operar en tiempo constante.
          </p>
        </div>
        <div class="fifo-flow__steps">
          <article>
            <span>Nodo</span>
            <h3>Datos por cliente</h3>
            <p>Cada nodo almacena el `codigo`, el `nombre` y una referencia `next` hacia el nodo siguiente.</p>
          </article>
          <article>
            <span>Front</span>
            <h3>Inicio de la cola</h3>
            <p>`front` apunta al primer nodo y define quién debe ser atendido cuando se ejecuta `dequeue`.</p>
          </article>
          <article>
            <span>Rear</span>
            <h3>Fin de la cola</h3>
            <p>`rear` apunta al último nodo. Cuando llega un cliente nuevo, `rear.next` enlaza el nodo y luego `rear` avanza.</p>
          </article>
        </div>
        <div class="fifo-ops-grid">
          <article class="fifo-op-card">
            <h3>`enqueue(codigo, nombre)`</h3>
            <p>Crea un nodo nuevo, lo enlaza al final y actualiza `rear`. Si la cola está vacía, `front` y `rear` apuntan al mismo nodo.</p>
            <strong>Complejidad: O(1)</strong>
          </article>
          <article class="fifo-op-card">
            <h3>`dequeue()`</h3>
            <p>Extrae el nodo del frente y mueve `front` al siguiente. Si no quedan nodos, `rear` pasa a `null`.</p>
            <strong>Complejidad: O(1)</strong>
          </article>
          <article class="fifo-op-card">
            <h3>`peek()` y `isEmpty()`</h3>
            <p>Permiten consultar el frente actual o validar si la cola está vacía sin recorrer toda la estructura.</p>
            <strong>Complejidad: O(1)</strong>
          </article>
        </div>
      </section>

      <section class="fifo-demo ds-panel" id="demo-fifo">
        <div class="fifo-demo__head">
          <div>
            <p class="ds-eyebrow">Demo interactiva</p>
            <h2>Simulación del turnero bancario</h2>
            <p>Agrega clientes, atiende el siguiente turno y observa cómo la cola respeta FIFO tanto en el tablero operativo como en la estructura enlazada.</p>
          </div>
          <div class="fifo-demo__actions">
            <button class="btn btn-primary" id="fifo-add" type="button">Agregar turno</button>
            <button class="btn btn-secondary" id="fifo-next" type="button">Atender siguiente</button>
            <button class="btn btn-ghost" id="fifo-reset" type="button">Reiniciar</button>
          </div>
        </div>

        <div class="fifo-form">
          <label for="fifo-name">Nombre del cliente</label>
          <input id="fifo-name" name="fifo-name" type="text" placeholder="Ej. Mariana Torres" autocomplete="off" />
          <p id="fifo-feedback" class="fifo-feedback" aria-live="polite">La cola inicia con tres turnos de ejemplo para mostrar el comportamiento base.</p>
        </div>

        <div class="fifo-dashboard">
          <article>
            <span>Turno en atención</span>
            <strong id="fifo-current">A001 · Laura Diaz</strong>
          </article>
          <article>
            <span>En espera</span>
            <strong id="fifo-count">3 clientes</strong>
          </article>
          <article>
            <span>Último atendido</span>
            <strong id="fifo-last">Aun no hay registros</strong>
          </article>
          <article>
            <span>Front</span>
            <strong id="fifo-front">A001</strong>
          </article>
          <article>
            <span>Rear</span>
            <strong id="fifo-rear">A003</strong>
          </article>
          <article>
            <span>Tamaño</span>
            <strong id="fifo-size">3 nodos</strong>
          </article>
        </div>

        <div class="fifo-op-state">
          <article>
            <span>Operación actual</span>
            <strong id="fifo-op-name">Estado inicial</strong>
          </article>
          <article>
            <span>Explicación</span>
            <p id="fifo-op-detail">`front` apunta a A001, `rear` apunta a A003 y cada nodo intermedio conserva la referencia `next` hacia el siguiente.</p>
          </article>
          <article>
            <span>Sección del código activa</span>
            <p id="fifo-op-code">Atributos de la cola, creación de nodos y avance del frente.</p>
          </article>
        </div>

        <div class="fifo-demo__content fifo-demo__content--wide">
          <div class="fifo-queue-panel">
            <div class="fifo-section-head">
              <h3>Cola actual</h3>
              <span>Vista de negocio del turno</span>
            </div>
            <div class="fifo-queue" id="fifo-queue" aria-live="polite"></div>
          </div>

          <div class="fifo-queue-panel fifo-queue-panel--structure" id="fifo-structure-lab">
            <div class="fifo-section-head">
              <h3>Estructura enlazada</h3>
              <span>Nodos horizontales con punteros `next`</span>
            </div>
            <div class="fifo-structure-wrap">
              <div class="fifo-structure" id="fifo-structure" aria-live="polite"></div>
            </div>
          </div>

          <div class="fifo-history-panel">
            <div class="fifo-section-head">
              <h3>Historial de atención</h3>
              <span>Salida en orden de servicio</span>
            </div>
            <ul id="fifo-history" class="fifo-history"></ul>

            <div class="fifo-trace-block">
              <div class="fifo-section-head fifo-section-head--stacked">
                <h3>Bitácora de punteros</h3>
                <span>Cambios recientes en `front`, `rear` y `next`</span>
              </div>
              <ul id="fifo-trace" class="fifo-trace"></ul>
            </div>
          </div>
        </div>
      </section>

      <section class="ds-panel zona-codigo zona-codigo--java">
        <div class="encabezado-cuadro">
          <h2><img src="/icons/rocket.svg" alt="" class="ui-icon" aria-hidden="true" />Lógica Java de la cola</h2>
          <span class="codigo-badge">Referencia conceptual</span>
        </div>
        <div class="fifo-java-intro">
          <p>
            El siguiente bloque presenta la clase completa en una sola vista. Los comentarios separan cada parte de la lógica,
            mientras el simulador resalta la sección activa cuando cambian `front`, `rear` o la referencia `next`.
          </p>
        </div>
        <div class="fifo-code-editor" aria-label="Código Java completo del turnero bancario">
          <div class="fifo-code-editor__bar">
            <span></span><span></span><span></span>
          </div>
          <div class="fifo-code-view" id="fifo-code-view">
            <div class="fifo-code-block" data-code-block="queue-fields">
              <span class="fifo-code-line">public class ColaTurnosBanco {'{'}</span>
              <span class="fifo-code-line fifo-code-comment">  // Referencias principales de la cola</span>
              <span class="fifo-code-line">  private Nodo frente;</span>
              <span class="fifo-code-line">  private Nodo fin;</span>
              <span class="fifo-code-line">  private int size;</span>
            </div>

            <div class="fifo-code-block" data-code-block="node-class">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">  // Nodo enlazado que representa un turno del banco</span>
              <span class="fifo-code-line">  private static class Nodo {'{'}</span>
              <span class="fifo-code-line">    String codigo;</span>
              <span class="fifo-code-line">    String nombre;</span>
              <span class="fifo-code-line">    Nodo next;</span>
              <span class="fifo-code-line">&nbsp;</span>
              <span class="fifo-code-line">    Nodo(String codigo, String nombre) {'{'}</span>
              <span class="fifo-code-line">      this.codigo = codigo;</span>
              <span class="fifo-code-line">      this.nombre = nombre;</span>
              <span class="fifo-code-line">    {'}'}</span>
              <span class="fifo-code-line">  {'}'}</span>
            </div>

            <div class="fifo-code-block" data-code-block="enqueue-create">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">  // Agrega un nuevo cliente al final de la cola</span>
              <span class="fifo-code-line">  public void encolar(String codigo, String nombre) {'{'}</span>
              <span class="fifo-code-line">    Nodo nuevo = new Nodo(codigo, nombre);</span>
            </div>

            <div class="fifo-code-block" data-code-block="enqueue-empty">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">    // Si la cola está vacía, el nuevo nodo será frente y fin</span>
              <span class="fifo-code-line">    if (estaVacia()) {'{'}</span>
              <span class="fifo-code-line">      frente = nuevo;</span>
              <span class="fifo-code-line">      fin = nuevo;</span>
              <span class="fifo-code-line">    {'}'} else {'{'}</span>
            </div>

            <div class="fifo-code-block" data-code-block="enqueue-link">
              <span class="fifo-code-line fifo-code-comment">      // Enlaza el nodo desde el final actual y mueve el puntero fin</span>
              <span class="fifo-code-line">      fin.next = nuevo;</span>
              <span class="fifo-code-line">      fin = nuevo;</span>
              <span class="fifo-code-line">    {'}'}</span>
            </div>

            <div class="fifo-code-block" data-code-block="enqueue-size">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">    // La cola gana un elemento</span>
              <span class="fifo-code-line">    size++;</span>
              <span class="fifo-code-line">  {'}'}</span>
            </div>

            <div class="fifo-code-block" data-code-block="dequeue-guard">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">  // Atiende al cliente del frente y protege el caso de cola vacía</span>
              <span class="fifo-code-line">  public String desencolar() {'{'}</span>
              <span class="fifo-code-line">    if (estaVacia()) {'{'}</span>
              <span class="fifo-code-line">      return null;</span>
              <span class="fifo-code-line">    {'}'}</span>
            </div>

            <div class="fifo-code-block" data-code-block="dequeue-front">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">    // Guarda el turno atendido y mueve frente al siguiente nodo</span>
              <span class="fifo-code-line">    Nodo atendido = frente;</span>
              <span class="fifo-code-line">    frente = frente.next;</span>
            </div>

            <div class="fifo-code-block" data-code-block="dequeue-empty-tail">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">    // Si ya no queda frente, la cola también pierde el fin</span>
              <span class="fifo-code-line">    if (frente == null) {'{'}</span>
              <span class="fifo-code-line">      fin = null;</span>
              <span class="fifo-code-line">    {'}'}</span>
            </div>

            <div class="fifo-code-block" data-code-block="dequeue-size">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">    // La cola pierde un elemento y devuelve el turno atendido</span>
              <span class="fifo-code-line">    size--;</span>
              <span class="fifo-code-line">    return atendido.codigo + " - " + atendido.nombre;</span>
              <span class="fifo-code-line">  {'}'}</span>
            </div>

            <div class="fifo-code-block" data-code-block="peek">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">  // Consulta el cliente actual del frente sin retirarlo</span>
              <span class="fifo-code-line">  public String verFrente() {'{'}</span>
              <span class="fifo-code-line">    return estaVacia() ? null : frente.codigo + " - " + frente.nombre;</span>
              <span class="fifo-code-line">  {'}'}</span>
            </div>

            <div class="fifo-code-block" data-code-block="is-empty">
              <span class="fifo-code-line fifo-code-comment">&nbsp;</span>
              <span class="fifo-code-line fifo-code-comment">  // Valida si no existe ningún nodo enlazado</span>
              <span class="fifo-code-line">  public boolean estaVacia() {'{'}</span>
              <span class="fifo-code-line">    return frente == null;</span>
              <span class="fifo-code-line">  {'}'}</span>
              <span class="fifo-code-line">{'}'}</span>
            </div>
          </div>
        </div>
      </section>

      <section class="catalog-back-actions ds-panel">
        <div>
          <p class="ds-eyebrow">Navegación del proyecto</p>
          <h2>Volver al catálogo de aplicativos</h2>
          <p>Regresa al listado para abrir otra demo FIFO/FILO o revisar los próximos aplicativos.</p>
        </div>
        <div class="catalog-back-actions__buttons">
          <a class="btn btn-primary" href={`/parciales/${parcial.slug}`}>Volver al catálogo del proyecto</a>
          <a class="btn btn-ghost" href="/">Ir a la portada</a>
        </div>
      </section>
    </main>
  ) : esFifo2 ? (
    <main class="print-shell" id="contenido-principal">
      <section class="print-hero">
        <div class="print-hero__copy">
          <div class="fifo-hero__eyebrow-row">
            <p class="ds-eyebrow">Proyecto final · Aplicativo disponible</p>
            <span class="fifo-chip">Cola de impresión</span>
          </div>
          <h1>FIFO 2: <span>Cola de impresión</span></h1>
          <p class="fifo-hero__lead">
            Sistema web para gestionar trabajos de impresión con una cola FIFO: cada documento se procesa en el mismo orden
            en que fue enviado, mostrando `front`, `rear` y los enlaces `next` de la estructura.
          </p>
          <div class="fifo-hero__story">
            <div>
              <span>Regla central</span>
              <strong>First In, First Out</strong>
            </div>
            <div>
              <span>Operaciones</span>
              <strong>`enqueue` y `dequeue`</strong>
            </div>
            <div>
              <span>Complejidad base</span>
              <strong>O(1)</strong>
            </div>
          </div>
          <div class="fifo-hero__actions">
            <a class="btn btn-primary" href="#demo-impresion">Probar demo</a>
            <a class="btn btn-secondary" href="#codigo-impresion">Ver lógica Java</a>
            <a class="btn btn-ghost" href={`/parciales/${parcial.slug}`}>Volver al catálogo</a>
          </div>
        </div>

        <div class="print-hero__panel ds-panel">
          <div class="hero-kpis">
            <article>
              <span>Estructura</span>
              <strong>FIFO</strong>
            </article>
            <article>
              <span>Contexto</span>
              <strong>Impresora</strong>
            </article>
            <article>
              <span>Stack lógico</span>
              <strong>Java</strong>
            </article>
          </div>
          <div class="print-preview" aria-label="Vista previa de trabajos de impresión">
            {trabajosImpresionIniciales.map((trabajo, index) => (
              <div class={`print-preview__node ${index === 0 ? "print-preview__node--front" : index === trabajosImpresionIniciales.length - 1 ? "print-preview__node--rear" : ""}`}>
                <span>{trabajo.codigo}</span>
                <strong>{trabajo.nombre}</strong>
                <small>{index === 0 ? "Front" : index === trabajosImpresionIniciales.length - 1 ? "Rear" : "Nodo"}</small>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="fifo-grid-info">
        <article class="ds-panel fifo-info-card">
          <p class="ds-eyebrow">Problema de impresión</p>
          <h2>Orden y trazabilidad en impresoras</h2>
          <p>
            En una oficina, cada usuario espera que la impresora respete el orden de envío de sus documentos. Una cola FIFO
            registra trabajos, mantiene visible el frente y evita saltos manuales entre documentos.
          </p>
          <ul class="fifo-bullet-list">
            <li>Evita colisiones y saltos en el orden de impresión.</li>
            <li>Permite ver el siguiente trabajo y el último de la cola.</li>
            <li>Deja una bitácora simple de cambios en `front`, `rear` y `next`.</li>
