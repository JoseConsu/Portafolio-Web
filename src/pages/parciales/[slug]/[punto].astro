    gap: var(--sp-3);
    min-height: 220px;
    min-width: max-content;
  }

  .fifo-structure-piece {
    display: grid;
    gap: var(--sp-2);
    min-width: 180px;
  }

  .fifo-pointer-row {
    display: flex;
    gap: var(--sp-2);
    min-height: 28px;
  }

  .fifo-pointer {
