      <section class="ds-panel zona-codigo zona-codigo--java">
        <div class="encabezado-cuadro">
          <h2>Lógica Java de la pila</h2>
          <span class="codigo-badge">Referencia conceptual</span>
        </div>
        <div class="filo-java-intro">
          <p>El simulador resalta la misma operación que usaría una pila enlazada en Java para gestionar solicitudes de soporte.</p>
        </div>
        <div class="filo-code-editor" aria-label="Código Java completo de la bandeja de procesos">
          <div class="filo-code-editor__bar"><span></span><span></span><span></span></div>
          <div class="filo-code-view" id="filo2-code-view">
            <div class="filo-code-block" data-filo2-code-block="stack-fields"><span class="filo-code-line">public class BandejaProcesos {'{'}</span><span class="filo-code-line filo-code-comment">  // Nodo de la cima y contador de la pila</span><span class="filo-code-line">  private Nodo top;</span><span class="filo-code-line">  private int size;</span></div>
            <div class="filo-code-block" data-filo2-code-block="node-class"><span class="filo-code-line filo-code-comment">  // Nodo enlazado que representa una solicitud</span><span class="filo-code-line">  private static class Nodo {'{'}</span><span class="filo-code-line">    String codigo, nombre, categoria, prioridad;</span><span class="filo-code-line">    Nodo next;</span><span class="filo-code-line">  {'}'}</span></div>
            <div class="filo-code-block" data-filo2-code-block="push-insert"><span class="filo-code-line filo-code-comment">  // Registra una nueva solicitud en la cima</span><span class="filo-code-line">  public void push(Nodo nuevo) {'{'}</span><span class="filo-code-line">    nuevo.next = top;</span><span class="filo-code-line">    top = nuevo;</span><span class="filo-code-line">    size++;</span><span class="filo-code-line">  {'}'}</span></div>
            <div class="filo-code-block" data-filo2-code-block="pop-extract"><span class="filo-code-line filo-code-comment">  // Resuelve la solicitud del tope</span><span class="filo-code-line">  public Nodo pop() {'{'}</span><span class="filo-code-line">    if (estaVacia()) return null;</span><span class="filo-code-line">    Nodo resuelto = top;</span><span class="filo-code-line">    top = top.next;</span><span class="filo-code-line">    size--;</span><span class="filo-code-line">    return resuelto;</span><span class="filo-code-line">  {'}'}</span></div>
            <div class="filo-code-block" data-filo2-code-block="peek"><span class="filo-code-line filo-code-comment">  // Consulta la cima actual sin extraerla</span><span class="filo-code-line">  public Nodo peek() {'{'} return top; {'}'}</span></div>
            <div class="filo-code-block" data-filo2-code-block="is-empty"><span class="filo-code-line filo-code-comment">  // Valida si no existe ningún nodo en la pila</span><span class="filo-code-line">  public boolean estaVacia() {'{'} return top == null; {'}'}</span><span class="filo-code-line">{'}'}</span></div>
          </div>
        </div>
