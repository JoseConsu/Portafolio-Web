  <script is:inline define:vars={{ turnosIniciales, trabajosImpresionIniciales, accionesFiloIniciales }}>
    const botonCopiar = document.querySelector(".boton-copiar");
    const nodoCodigo = document.querySelector(".cuadro-codigo");

    botonCopiar?.addEventListener("click", async () => {
      if (!nodoCodigo) return;

      const texto = nodoCodigo.textContent ?? "";
      const iconoOriginal = botonCopiar?.querySelector("svg")?.cloneNode(true);

      try {
        await navigator.clipboard.writeText(texto);
        botonCopiar.textContent = "✅";
        setTimeout(() => {
          botonCopiar?.replaceChildren();
          if (iconoOriginal) {
            botonCopiar?.appendChild(iconoOriginal.cloneNode(true));
          }
        }, 1400);
      } catch {
        const seleccion = window.getSelection();
        const rango = document.createRange();
        rango.selectNodeContents(nodoCodigo);
        seleccion?.removeAllRanges();
        seleccion?.addRange(rango);
      }
    });

    const queueRoot = document.querySelector("#fifo-queue");
    if (queueRoot) {
      const historyRoot = document.querySelector("#fifo-history");
      const structureRoot = document.querySelector("#fifo-structure");
      const traceRoot = document.querySelector("#fifo-trace");
      const feedbackNode = document.querySelector("#fifo-feedback");
      const inputNode = document.querySelector("#fifo-name");
      const currentNode = document.querySelector("#fifo-current");
      const countNode = document.querySelector("#fifo-count");
      const lastNode = document.querySelector("#fifo-last");
      const frontNode = document.querySelector("#fifo-front");
      const rearNode = document.querySelector("#fifo-rear");
      const sizeNode = document.querySelector("#fifo-size");
      const opNameNode = document.querySelector("#fifo-op-name");
      const opDetailNode = document.querySelector("#fifo-op-detail");
      const opCodeNode = document.querySelector("#fifo-op-code");
      const addButton = document.querySelector("#fifo-add");
      const nextButton = document.querySelector("#fifo-next");
      const resetButton = document.querySelector("#fifo-reset");
      const codeBlocks = Array.from(document.querySelectorAll("[data-code-block]"));
      const metricNodes = {
        current: currentNode?.closest("article") ?? null,
        count: countNode?.closest("article") ?? null,
        last: lastNode?.closest("article") ?? null,
        front: frontNode?.closest("article") ?? null,
        rear: rearNode?.closest("article") ?? null,
        size: sizeNode?.closest("article") ?? null,
      };

      const initialQueue = turnosIniciales.map((turno) => ({ ...turno }));
      let queue = initialQueue.map((turno) => ({ ...turno }));
      let history = [];
      let trace = [
        "Estado inicial: front = A001, rear = A003 y A001.next apunta a A002.",
        "Los nodos intermedios mantienen el enlace next hasta llegar al final de la cola.",
      ];
      let nextId = initialQueue.length + 1;
      let operationTitle = "Estado inicial";
      let operationDetail = "La cola comienza con tres nodos enlazados. `front` apunta a A001 y `rear` apunta a A003.";
      let operationCode = "Atributos de la cola, definición del nodo y enlace del final.";
      let activeCodeBlocks = ["queue-fields", "node-class", "enqueue-link"];
      let animationState = {
        type: "idle",
        phase: "complete",
        focusCode: null,
        frontCode: queue[0]?.codigo ?? null,
        rearCode: queue[queue.length - 1]?.codigo ?? null,
        activeArrowFrom: null,
        exitingCode: null,
        incomingCode: null,
        metricKeys: ["front", "rear", "size"],
      };
      let animationStepTimeouts = [];

      const formatoTurno = (turno) => `${turno.codigo} · ${turno.nombre}`;
      const formatoRef = (turno) => (turno ? turno.codigo : "null");

      const registrarTrazas = (...lineas) => {
        trace = [...lineas, ...trace].slice(0, 7);
      };

      const clearAnimationTimers = () => {
        animationStepTimeouts.forEach((timer) => window.clearTimeout(timer));
        animationStepTimeouts = [];
      };

      const setCodeHighlights = (blocks = []) => {
        activeCodeBlocks = blocks;
        codeBlocks.forEach((block) => {
          const key = block.getAttribute("data-code-block") ?? "";
          const stateIndex = blocks.indexOf(key);
          block.classList.toggle("fifo-code-block--active", stateIndex === 0);
          block.classList.toggle("fifo-code-block--related", stateIndex > 0);
        });
      };

      const setAnimationState = (state = {}) => {
        animationState = {
          type: state.type ?? animationState.type,
          phase: state.phase ?? animationState.phase,
          focusCode: state.focusCode ?? null,
          frontCode: state.frontCode ?? queue[0]?.codigo ?? null,
          rearCode: state.rearCode ?? queue[queue.length - 1]?.codigo ?? null,
          activeArrowFrom: state.activeArrowFrom ?? null,
          exitingCode: state.exitingCode ?? null,
          incomingCode: state.incomingCode ?? null,
          metricKeys: state.metricKeys ?? [],
        };
        if (state.codeBlocks) {
          setCodeHighlights(state.codeBlocks);
        }
        render();
      };

      const runSequence = (steps) => {
        clearAnimationTimers();
        let delay = 0;
        for (const step of steps) {
          const timer = window.setTimeout(() => {
            if (step.operationTitle) operationTitle = step.operationTitle;
            if (step.operationDetail) operationDetail = step.operationDetail;
            if (step.operationCode) operationCode = step.operationCode;
            setAnimationState(step.animationState ?? {});
          }, delay);
          animationStepTimeouts.push(timer);
          delay += step.duration ?? 220;
        }
      };

      const render = () => {
        if (currentNode) {
          currentNode.textContent = queue[0] ? formatoTurno(queue[0]) : "Sin clientes en espera";
        }

        if (countNode) {
          const total = queue.length;
          countNode.textContent = `${total} ${total === 1 ? "cliente" : "clientes"}`;
        }

        if (lastNode) {
          lastNode.textContent = history[0] ? formatoTurno(history[0]) : "Aun no hay registros";
        }

        if (frontNode) {
          frontNode.textContent = formatoRef(queue[0]);
        }

        if (rearNode) {
          rearNode.textContent = formatoRef(queue[queue.length - 1]);
        }

        if (sizeNode) {
          sizeNode.textContent = `${queue.length} ${queue.length === 1 ? "nodo" : "nodos"}`;
        }

        if (opNameNode) {
          opNameNode.textContent = operationTitle;
        }

        if (opDetailNode) {
          opDetailNode.textContent = operationDetail;
        }

        if (opCodeNode) {
          opCodeNode.textContent = operationCode;
        }

        Object.entries(metricNodes).forEach(([key, article]) => {
          article?.classList.toggle("fifo-metric--active", animationState.metricKeys.includes(key));
        });

        queueRoot.replaceChildren();

        if (queue.length === 0) {
          const empty = document.createElement("div");
          empty.className = "fifo-queue__empty";
          empty.textContent = "La cola está vacía. Agrega un nuevo turno para continuar la simulación.";
          queueRoot.appendChild(empty);
        } else {
          queue.forEach((turno, index) => {
            const card = document.createElement("article");
            const clases = ["fifo-turno"];
            if (index === 0) clases.push("fifo-turno--front");
            if (animationState.focusCode === turno.codigo) clases.push("fifo-turno--focus");
            if (animationState.incomingCode === turno.codigo) clases.push("fifo-turno--anim-enter");
            if (animationState.exitingCode === turno.codigo) clases.push("fifo-turno--anim-exit");
            card.className = clases.join(" ");
            card.innerHTML = `<span>${index === 0 ? "En frente" : `Posición ${index + 1}`}</span><strong>${turno.codigo}</strong><p>${turno.nombre}</p>`;
            queueRoot.appendChild(card);
          });
        }

        structureRoot?.replaceChildren();

        if (queue.length === 0) {
          const emptyStructure = document.createElement("div");
          emptyStructure.className = "fifo-structure-empty";
          emptyStructure.innerHTML = "<strong>Front = null</strong><span>Rear = null</span><p>No existen nodos enlazados en este momento.</p>";
          structureRoot?.appendChild(emptyStructure);
        } else {
          queue.forEach((turno, index) => {
            const piece = document.createElement("div");
            piece.className = "fifo-structure-piece";

            const pointerTop = [];
            if (index === 0) pointerTop.push(`<span class="fifo-pointer fifo-pointer--front ${animationState.frontCode === turno.codigo ? "fifo-pointer--active" : ""}">Front</span>`);
            if (index === queue.length - 1) pointerTop.push(`<span class="fifo-pointer fifo-pointer--rear ${animationState.rearCode === turno.codigo ? "fifo-pointer--active" : ""}">Rear</span>`);

            const nodeClasses = ["fifo-node"];
            if (index === 0) nodeClasses.push("fifo-node--front");
            if (index === queue.length - 1) nodeClasses.push("fifo-node--rear");
            if (animationState.focusCode === turno.codigo) nodeClasses.push("fifo-node--focus");
            if (animationState.incomingCode === turno.codigo) nodeClasses.push("fifo-node--incoming");
            if (animationState.exitingCode === turno.codigo) nodeClasses.push("fifo-node--outgoing");
            if (animationState.frontCode === turno.codigo) nodeClasses.push("fifo-node--front-active");
            if (animationState.rearCode === turno.codigo) nodeClasses.push("fifo-node--rear-active");

            piece.innerHTML = `
              <div class="fifo-pointer-row">${pointerTop.join("")}</div>
              <article class="${nodeClasses.join(" ")}">
                <span class="fifo-node__label">Nodo ${index + 1}</span>
                <strong>${turno.codigo}</strong>
                <p>${turno.nombre}</p>
                <small>next: ${queue[index + 1] ? queue[index + 1].codigo : "null"}</small>
              </article>
            `;

            structureRoot?.appendChild(piece);

            if (index < queue.length - 1) {
              const arrow = document.createElement("div");
              arrow.className = `fifo-arrow ${animationState.activeArrowFrom === turno.codigo ? "fifo-arrow--active" : ""}`;
              arrow.innerHTML = '<span>next</span><strong>→</strong>';
              structureRoot?.appendChild(arrow);
            } else {
              const nullArrow = document.createElement("div");
              nullArrow.className = `fifo-arrow fifo-arrow--null ${animationState.activeArrowFrom === turno.codigo ? "fifo-arrow--active" : ""}`;
              nullArrow.innerHTML = '<span>next</span><strong>null</strong>';
              structureRoot?.appendChild(nullArrow);
            }
          });
        }

        historyRoot?.replaceChildren();

        if (history.length === 0) {
          const item = document.createElement("li");
          item.className = "fifo-history__empty";
          item.textContent = "Todavía no se ha atendido ningún cliente.";
          historyRoot?.appendChild(item);
        } else {
          history.forEach((turno) => {
            const item = document.createElement("li");
            item.textContent = formatoTurno(turno);
            historyRoot?.appendChild(item);
          });
        }

        traceRoot?.replaceChildren();
        trace.forEach((linea) => {
          const item = document.createElement("li");
          item.textContent = linea;
          traceRoot?.appendChild(item);
        });
      };

      addButton?.addEventListener("click", () => {
        const nombre = inputNode instanceof HTMLInputElement ? inputNode.value.trim() : "";
        if (!nombre) {
          if (feedbackNode) {
            feedbackNode.textContent = "Ingresa el nombre del cliente antes de generar un nuevo turno.";
          }
          inputNode?.focus();
          return;
        }

        const codigo = `A${String(nextId).padStart(3, "0")}`;
        const previousRear = queue[queue.length - 1] ?? null;
        nextId += 1;
        queue.push({ codigo, nombre });
        if (previousRear) {
          registrarTrazas(
            `enqueue(${codigo}, ${nombre})`,
            `Se crea el nodo ${codigo}`,
            `${previousRear.codigo}.next = ${codigo}`,
            `rear = ${codigo}`,
            `size = ${queue.length}`
          );
          runSequence([
            {
              operationTitle: `enqueue(${codigo}, ${nombre})`,
              operationDetail: `Se crea el nodo ${codigo} para ${nombre}, pero todavía no está enlazado al final de la cola.`,
              operationCode: "Se activa la creación del nuevo nodo dentro de `encolar`.",
              animationState: {
                type: "enqueue",
                phase: "start",
                focusCode: codigo,
                incomingCode: codigo,
                rearCode: previousRear.codigo,
                metricKeys: ["rear", "size"],
                codeBlocks: ["enqueue-create", "node-class"],
              },
              duration: 180,
            },
            {
              operationDetail: `Ahora ${previousRear.codigo}.next apunta a ${codigo} y el puntero rear se prepara para avanzar.`,
              operationCode: "Se activa la parte donde `fin.next` enlaza el nodo y `fin` avanza al nuevo final.",
              animationState: {
                type: "enqueue",
                phase: "link",
                focusCode: codigo,
                incomingCode: codigo,
                rearCode: codigo,
                activeArrowFrom: previousRear.codigo,
                metricKeys: ["rear"],
                codeBlocks: ["enqueue-link", "queue-fields"],
              },
              duration: 280,
            },
            {
              operationDetail: `La operación termina con rear = ${codigo} y size = ${queue.length}. La cola mantiene FIFO intacto.`,
              operationCode: "Se activa el cierre de `encolar`, donde la cola ya enlazó el nodo y actualiza su tamaño.",
              animationState: {
                type: "enqueue",
                phase: "complete",
                focusCode: codigo,
                rearCode: codigo,
                metricKeys: ["rear", "size", "count"],
                codeBlocks: ["enqueue-size", "enqueue-link", "queue-fields"],
              },
              duration: 220,
            },
          ]);
        } else {
          registrarTrazas(
            `enqueue(${codigo}, ${nombre})`,
            `Se crea el nodo ${codigo}`,
            `front = ${codigo}`,
            `rear = ${codigo}`,
            `size = ${queue.length}`
          );
          runSequence([
            {
              operationTitle: `enqueue(${codigo}, ${nombre})`,
              operationDetail: `Se crea el nodo ${codigo} para ${nombre} sobre una cola vacía.`,
              operationCode: "Se activa la creación del nodo nuevo a partir de la estructura `Nodo`.",
              animationState: {
                type: "enqueue",
                phase: "start",
                focusCode: codigo,
                incomingCode: codigo,
                metricKeys: ["front", "rear", "size"],
                codeBlocks: ["enqueue-create", "node-class"],
              },
              duration: 180,
            },
            {
              operationDetail: `Como no había nodos, ${codigo} pasa a ser simultáneamente front y rear.`,
              operationCode: "Se activa la rama de cola vacía, donde el mismo nodo pasa a ser `frente` y `fin`.",
              animationState: {
                type: "enqueue",
                phase: "link",
                focusCode: codigo,
                incomingCode: codigo,
                frontCode: codigo,
                rearCode: codigo,
                metricKeys: ["front", "rear"],
                codeBlocks: ["enqueue-empty", "queue-fields"],
              },
              duration: 280,
            },
            {
              operationDetail: `La cola queda inicializada con un solo nodo y size = 1.`,
              operationCode: "Se activa el cierre de `encolar` con la cola ya inicializada y el tamaño actualizado.",
              animationState: {
                type: "enqueue",
                phase: "complete",
                focusCode: codigo,
                frontCode: codigo,
                rearCode: codigo,
                metricKeys: ["front", "rear", "size", "count"],
                codeBlocks: ["enqueue-size", "enqueue-empty", "queue-fields"],
              },
              duration: 220,
            },
          ]);
        }
        if (feedbackNode) {
          feedbackNode.textContent = `Se agregó ${codigo} para ${nombre} al final de la cola.`;
        }
        if (inputNode instanceof HTMLInputElement) {
          inputNode.value = "";
          inputNode.focus();
        }
      });

      nextButton?.addEventListener("click", () => {
        if (queue.length === 0) {
          operationTitle = "dequeue() sobre cola vacía";
          operationDetail = "No se puede atender un cliente porque front y rear ya están en null.";
          operationCode = "Se activa la validación que protege `desencolar` cuando no hay nodos en la cola.";
          registrarTrazas("dequeue() abortado", "La cola está vacía: front = null, rear = null");
          if (feedbackNode) {
            feedbackNode.textContent = "No hay clientes en espera. Agrega un nuevo turno para continuar.";
          }
          runSequence([
            {
              animationState: {
                type: "empty",
                phase: "start",
                metricKeys: ["front", "rear"],
                codeBlocks: ["dequeue-guard", "is-empty"],
              },
              duration: 260,
            },
          ]);
          return;
        }

        const atendido = queue[0];
        const previousRear = queue[queue.length - 1];
        const nextFront = queue[1] ?? null;
        const queueWillBeEmpty = queue.length === 1;
        history.unshift(atendido);
        queue = queue.slice(1);

        registrarTrazas(
          `dequeue() -> ${atendido.codigo}`,
          queue[0] ? `front = ${queue[0].codigo}` : "front = null",
          queueWillBeEmpty ? "rear = null" : `rear = ${previousRear.codigo}`,
          `size = ${queue.length}`
        );

        operationTitle = `dequeue() -> ${atendido.codigo}`;
        if (queue[0]) {
          operationDetail = `El nodo ${atendido.codigo} abandona el frente. El nuevo front será ${queue[0].codigo} y rear permanece en ${previousRear.codigo}.`;
          operationCode = "Se activa la parte donde `frente` avanza a `frente.next` sin mover el puntero `fin`.";
        } else {
          operationDetail = `El nodo ${atendido.codigo} era el único elemento, por eso después de atenderlo front y rear quedan en null.`;
          operationCode = "Se activa la parte donde el último nodo sale y tanto `frente` como `fin` quedan en `null`.";
        }

        if (feedbackNode) {
          feedbackNode.textContent = `${atendido.codigo} de ${atendido.nombre} fue atendido correctamente.`;
        }

        if (queueWillBeEmpty) {
          runSequence([
            {
              animationState: {
                type: "dequeue",
                phase: "start",
                focusCode: atendido.codigo,
                exitingCode: atendido.codigo,
                frontCode: atendido.codigo,
                rearCode: atendido.codigo,
                metricKeys: ["front", "rear", "current"],
                codeBlocks: ["dequeue-front", "queue-fields"],
              },
              duration: 180,
            },
            {
              operationDetail: `Tras retirar ${atendido.codigo}, la cola ya no tiene nodos enlazados. front = null y rear = null.`,
              operationCode: "Se activa la parte donde el último nodo sale y tanto `frente` como `fin` quedan en `null`.",
              animationState: {
                type: "dequeue",
                phase: "shift",
                exitingCode: atendido.codigo,
                metricKeys: ["front", "rear", "size", "count"],
                codeBlocks: ["dequeue-empty-tail", "dequeue-front", "queue-fields"],
              },
              duration: 300,
            },
            {
              operationDetail: `La operación termina con size = 0 y la cola lista para recibir un nuevo primer nodo.`,
              operationCode: "Se activa el cierre de `desencolar`, dejando la cola vacía y el tamaño en cero.",
              animationState: {
                type: "dequeue",
                phase: "complete",
                metricKeys: ["size", "count"],
                codeBlocks: ["dequeue-size", "dequeue-empty-tail", "queue-fields"],
              },
              duration: 220,
            },
          ]);
        } else {
          runSequence([
            {
              animationState: {
                type: "dequeue",
                phase: "start",
                focusCode: atendido.codigo,
                exitingCode: atendido.codigo,
                frontCode: atendido.codigo,
                rearCode: previousRear.codigo,
                metricKeys: ["front", "current"],
                codeBlocks: ["dequeue-front", "queue-fields"],
              },
              duration: 180,
            },
            {
              operationDetail: `El nodo ${atendido.codigo} se retira y front avanza a ${nextFront.codigo}. El puntero rear no cambia.`,
              operationCode: "Se mantiene activa la parte de avance del frente mientras el siguiente nodo pasa a ocupar esa referencia.",
              animationState: {
                type: "dequeue",
                phase: "shift",
                focusCode: nextFront.codigo,
                frontCode: nextFront.codigo,
                rearCode: previousRear.codigo,
                metricKeys: ["front", "rear", "current"],
                codeBlocks: ["dequeue-front", "queue-fields"],
              },
              duration: 300,
            },
            {
              operationDetail: `La cola queda con size = ${queue.length}. FIFO se conserva porque el nuevo frente es el siguiente nodo enlazado.`,
              operationCode: "Se activa el cierre de `desencolar`, con el nuevo frente ya definido y el tamaño reducido.",
              animationState: {
                type: "dequeue",
                phase: "complete",
                focusCode: nextFront.codigo,
                frontCode: nextFront.codigo,
                rearCode: previousRear.codigo,
                metricKeys: ["front", "rear", "size", "count"],
                codeBlocks: ["dequeue-size", "dequeue-front", "queue-fields"],
              },
              duration: 220,
            },
          ]);
        }
      });

      resetButton?.addEventListener("click", () => {
        clearAnimationTimers();
        queue = initialQueue.map((turno) => ({ ...turno }));
        history = [];
        trace = [
          "Reset: front = A001 y rear = A003 restaurados.",
          "La estructura vuelve a enlazar los turnos iniciales con referencias next consecutivas.",
        ];
        nextId = initialQueue.length + 1;
        operationTitle = "Reset de simulación";
        operationDetail = "La cola volvió a su configuración original con tres nodos enlazados y sin historial de atención.";
        operationCode = "Se restauran las referencias base de la cola y vuelve la estructura enlazada inicial.";
        if (inputNode instanceof HTMLInputElement) {
          inputNode.value = "";
        }
        if (feedbackNode) {
          feedbackNode.textContent = "La simulación volvió al estado inicial con los turnos de ejemplo.";
        }
        runSequence([
          {
            animationState: {
              type: "reset",
              phase: "start",
              frontCode: queue[0]?.codigo ?? null,
              rearCode: queue[queue.length - 1]?.codigo ?? null,
              metricKeys: ["front", "rear", "size", "count"],
              codeBlocks: ["queue-fields", "node-class", "enqueue-link"],
            },
            duration: 260,
          },
        ]);
      });

      setCodeHighlights(activeCodeBlocks);
      render();
    }

    const printRoot = document.querySelector("#print-root");
    if (printRoot) {
      const tableBody = document.querySelector("#print-table-body");
      const emptyNode = document.querySelector("#print-empty");
      const footerNode = document.querySelector("#print-footer");
      const statusNode = document.querySelector("#print-status");
      const progressNode = document.querySelector("#print-progress");
      const activeIconNode = document.querySelector("#print-active-icon");
      const activeNameNode = document.querySelector("#print-active-name");
      const activeMetaNode = document.querySelector("#print-active-meta");
      const frontNode = document.querySelector("#print-front");
      const rearNode = document.querySelector("#print-rear");
      const opNameNode = document.querySelector("#print-op-name");
      const opDetailNode = document.querySelector("#print-op-detail");
      const codeLabelNode = document.querySelector("#print-code-label");
      const linkedNode = document.querySelector("#print-linked");
      const historyNode = document.querySelector("#print-history");
      const logNode = document.querySelector("#print-log");
      const nameInput = document.querySelector("#print-name");
      const pagesInput = document.querySelector("#print-pages");
      const addButton = document.querySelector("#print-add");
      const nextButton = document.querySelector("#print-next");
      const resetButton = document.querySelector("#print-reset");

      const initialPrintQueue = trabajosImpresionIniciales.map((trabajo, index) => ({
        ...trabajo,
        sent: getPrintSentTime(index + 1),
      }));
      let printQueue = initialPrintQueue.map((trabajo) => ({ ...trabajo }));
      let printHistory = [];
      let printLog = [];
      let nextPrintId = initialPrintQueue.length + 1;
      let isPrinting = false;

      function getPrintTimestamp() {
        const now = new Date();
        return `${String(now.getHours()).padStart(2, "0")}:${String(now.getMinutes()).padStart(2, "0")}:${String(now.getSeconds()).padStart(2, "0")}`;
      }

      function getPrintSentTime(offset = 0) {
        const date = new Date(Date.now() - offset * 60000);
        return `${String(date.getHours()).padStart(2, "0")}:${String(date.getMinutes()).padStart(2, "0")}`;
      }

      function getDocIcon(nombre) {
        const ext = String(nombre).split(".").pop()?.toLowerCase();
        if (ext === "pdf") return "📕";
        if (ext === "doc" || ext === "docx") return "📘";
        if (ext === "xls" || ext === "xlsx" || ext === "csv") return "📗";
        if (ext === "ppt" || ext === "pptx") return "📙";
        if (["png", "jpg", "jpeg", "gif", "svg"].includes(ext ?? "")) return "🖼";
        return "📄";
      }

      function escapePrintHtml(value) {
        return String(value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function addPrintLog(tipo, texto) {
        printLog.push({ time: getPrintTimestamp(), tipo, texto });
      }

      function renderPrintQueue({ op = "Estado actual", detail = "", codeLabel = "Sección del código activa", printing = false } = {}) {
        const size = printQueue.length;
        const front = printQueue[0];
        const rear = printQueue[size - 1];

        if (opNameNode) opNameNode.textContent = op;
        if (opDetailNode) opDetailNode.innerHTML = detail;
        if (codeLabelNode) codeLabelNode.textContent = codeLabel;
        if (frontNode) frontNode.textContent = front?.codigo ?? "null";
        if (rearNode) rearNode.textContent = rear?.codigo ?? "null";

        isPrinting = printing && size > 0;
        printRoot.classList.toggle("is-printing", isPrinting);
        if (statusNode) statusNode.textContent = isPrinting ? "Imprimiendo" : size > 0 ? "En espera" : "Inactiva";
        progressNode?.classList.toggle("is-active", isPrinting);

        if (front) {
          if (activeIconNode) activeIconNode.textContent = getDocIcon(front.nombre);
          if (activeNameNode) activeNameNode.textContent = front.nombre;
          if (activeMetaNode) activeMetaNode.textContent = `${front.codigo} · ${front.paginas} páginas`;
        } else {
          if (activeIconNode) activeIconNode.textContent = "📄";
          if (activeNameNode) activeNameNode.textContent = "Cola vacía";
          if (activeMetaNode) activeMetaNode.textContent = "-";
        }

        if (tableBody) {
          tableBody.innerHTML = printQueue
            .map((trabajo, index) => {
              const estado = index === 0 ? "Imprimiendo" : "En espera";
              const rowClass = index === 0 ? "is-front" : index === size - 1 ? "is-rear" : "";
              return `<tr class="${rowClass}">
                <td>${trabajo.codigo}</td>
                <td>${getDocIcon(trabajo.nombre)} ${escapePrintHtml(trabajo.nombre)}</td>
                <td><span>${estado}</span></td>
                <td>${escapePrintHtml(trabajo.owner ?? "usuario")}</td>
                <td>${trabajo.paginas}</td>
                <td>${trabajo.sent ?? getPrintSentTime(size - index)}</td>
              </tr>`;
            })
            .join("");
        }

        if (emptyNode instanceof HTMLElement) emptyNode.hidden = size > 0;
        if (footerNode) footerNode.textContent = `${size} documento${size === 1 ? "" : "s"} en la cola`;

        if (linkedNode) {
          linkedNode.innerHTML = size === 0
            ? `<div class="print-empty-state">null</div>`
            : `${printQueue
                .map((trabajo, index) => {
                  const roleClass = index === 0 ? "is-front" : index === size - 1 ? "is-rear" : "";
                  const next = index < size - 1 ? printQueue[index + 1].codigo : "null";
                  const arrow = index < size - 1 ? `<span class="print-arrow">→</span>` : `<span class="print-null">→ null</span>`;
                  const nombreCorto = trabajo.nombre.length > 16 ? `${trabajo.nombre.slice(0, 15)}…` : trabajo.nombre;
                  return `<div class="print-node ${roleClass}"><strong>${trabajo.codigo}</strong><span>${escapePrintHtml(nombreCorto)}</span><small>next → ${next}</small></div>${arrow}`;
                })
                .join("")}`;
        }

        if (historyNode) {
          historyNode.innerHTML = printHistory.length === 0
            ? `<div class="print-empty-state">Sin registros aún</div>`
            : printHistory
                .slice()
                .reverse()
                .map((trabajo, index) => `<div><strong>${printHistory.length - index}. ${trabajo.codigo}</strong><span>${escapePrintHtml(trabajo.nombre)} · ${trabajo.paginas} pág.</span></div>`)
                .join("");
        }

        if (logNode) {
          logNode.innerHTML = printLog.length === 0
            ? `<div class="print-empty-state">Sin eventos</div>`
            : printLog
                .slice()
                .reverse()
                .slice(0, 20)
                .map((item) => `<div><strong>[${item.tipo.toUpperCase()}]</strong><span>${item.time} · ${escapePrintHtml(item.texto)}</span></div>`)
                .join("");
        }
      }

      function addPrintJob() {
        const nombre = nameInput instanceof HTMLInputElement && nameInput.value.trim()
          ? nameInput.value.trim().replace(/[<>]/g, "")
          : `Documento${nextPrintId}.pdf`;
        const paginas = pagesInput instanceof HTMLInputElement && Number.parseInt(pagesInput.value, 10) > 0
          ? Number.parseInt(pagesInput.value, 10)
          : Math.floor(Math.random() * 20) + 1;
        const codigo = `P${String(nextPrintId).padStart(3, "0")}`;
        const previousRear = printQueue.at(-1)?.codigo ?? null;

        nextPrintId += 1;
        printQueue.push({ codigo, nombre, paginas, owner: "usuario", sent: getPrintSentTime(0) });
        addPrintLog("enqueue", `${codigo} enlazado al final de la cola`);

        renderPrintQueue({
          op: `enqueue(${codigo})`,
          detail: previousRear
            ? `El nodo <strong>${codigo}</strong> se enlaza desde <strong>${previousRear}</strong> y <code>rear</code> avanza.`
            : `La cola estaba vacía: <code>front</code> y <code>rear</code> apuntan a <strong>${codigo}</strong>.`,
          codeLabel: "Encolar: fin.next = nuevo; fin = nuevo; size++",
        });

        if (nameInput instanceof HTMLInputElement) nameInput.value = "";
        if (pagesInput instanceof HTMLInputElement) pagesInput.value = "";
      }

      function processNextPrintJob() {
        if (isPrinting) return;

        if (printQueue.length === 0) {
          renderPrintQueue({ op: "Cola vacía", detail: "No hay trabajos pendientes para imprimir.", codeLabel: "estaVacia() → true" });
          return;
        }

        const current = printQueue[0];
        renderPrintQueue({
          op: `dequeue() → imprimiendo ${current.codigo}`,
          detail: `Procesando <strong>${current.codigo} · ${escapePrintHtml(current.nombre)}</strong>.`,
          codeLabel: "Desencolar: frente = frente.next; size--",
          printing: true,
        });

        setTimeout(() => {
          const processed = printQueue.shift();
          if (!processed) return;
          printHistory.push(processed);
          const nextFront = printQueue[0]?.codigo ?? "null";
          addPrintLog("dequeue", `${processed.codigo} impreso; front = ${nextFront}`);
          renderPrintQueue({
            op: `dequeue() → ${processed.codigo}`,
            detail: `Trabajo <strong>${processed.codigo}</strong> procesado. <code>front</code> avanza a <strong>${nextFront}</strong>${printQueue.length === 0 ? " y <code>rear</code> queda en null" : ""}.`,
            codeLabel: "Desencolar: frente = frente.next; size--",
          });
        }, 1600);
      }

      function resetPrintQueue() {
        printQueue = initialPrintQueue.map((trabajo) => ({ ...trabajo }));
        printHistory = [];
        printLog = [];
        nextPrintId = initialPrintQueue.length + 1;
        addPrintLog("reset", "Cola reiniciada con tres trabajos de ejemplo");
        renderPrintQueue({
          op: "Estado inicial",
          detail: "<code>front</code> apunta a P001, <code>rear</code> apunta a P003 y cada nodo conserva su referencia <code>next</code>.",
          codeLabel: "Atributos de la cola, creación de nodos y avance del frente",
        });
      }

      addButton?.addEventListener("click", addPrintJob);
      nextButton?.addEventListener("click", processNextPrintJob);
      resetButton?.addEventListener("click", resetPrintQueue);
      nameInput?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") addPrintJob();
      });
      pagesInput?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") addPrintJob();
      });

      resetPrintQueue();
    }

    const filoStackRoot = document.querySelector("#filo-stack");
    if (filoStackRoot) {
      const inputAccion = document.querySelector("#filo-name");
      const btnPush = document.querySelector("#filo-push");
      const btnPop = document.querySelector("#filo-pop");
      const btnReset = document.querySelector("#filo-reset");
      const feedback = document.querySelector("#filo-feedback");
      const topVal = document.querySelector("#filo-top-val");
      const countVal = document.querySelector("#filo-count");
      const lastVal = document.querySelector("#filo-last");
      const opName = document.querySelector("#filo-op-name");
      const opDetail = document.querySelector("#filo-op-detail");
      const opCode = document.querySelector("#filo-op-code");
      const structPanel = document.querySelector("#filo-structure");
      const historyList = document.querySelector("#filo-history");
      const traceList = document.querySelector("#filo-trace");
      const filoCodeBlocks = Array.from(document.querySelectorAll("[data-filo-code-block]"));

      let filoStack = [...accionesFiloIniciales];
      let filoHistory = [];
      let filoTrace = ["Estado inicial: top = 2 y size = 3."];

      function escapeFiloHtml(value) {
        return String(value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function setFiloCodeHighlights(active, related = []) {
        for (const block of filoCodeBlocks) {
          const key = block instanceof HTMLElement ? block.dataset.filoCodeBlock : "";
          block.classList.toggle("filo-code-block--active", key === active);
          block.classList.toggle("filo-code-block--related", related.includes(key ?? ""));
        }
      }

      function pushFiloTrace(...lines) {
        filoTrace = [...lines, ...filoTrace].slice(0, 8);
      }

      function updateFiloState({ op = "Estado actual", detail = "", code = "Atributos de la pila.", activeCode = "stack-fields", relatedCode = [] } = {}) {
        const top = filoStack.at(-1) ?? null;
        if (topVal) topVal.textContent = top ?? "- (pila vacía)";
        if (countVal) countVal.textContent = `${filoStack.length} acción${filoStack.length === 1 ? "" : "es"}`;
        if (lastVal) lastVal.textContent = filoHistory[0] ?? "Aún no hay registros";
        if (opName) opName.textContent = op;
        if (opDetail) opDetail.textContent = detail;
        if (opCode) opCode.textContent = code;

        filoStackRoot.innerHTML = filoStack.length === 0
          ? `<p class="filo-stack__empty">La pila está vacía.</p>`
          : filoStack
              .slice()
              .reverse()
              .map((accion, index) => `<div class="filo-turno ${index === 0 ? "filo-turno--top filo-turno--focus" : ""}"><span>${index === 0 ? "Cima - top" : "Nodo"}</span><strong>${escapeFiloHtml(accion)}</strong><p>índice ${filoStack.length - 1 - index}</p></div>`)
              .join("");

        if (structPanel) {
          structPanel.innerHTML = filoStack.length === 0
            ? `<div class="filo-stack-empty"><p>top = -1 · La pila no contiene elementos.</p></div>`
            : filoStack
                .map((accion, index) => ({ accion, index }))
                .reverse()
                .map(({ accion, index }) => {
                  const isTop = index === filoStack.length - 1;
                  const isBase = index === 0;
                  return `<div class="filo-stack-piece"><div class="filo-pointer-row">${isTop ? `<span class="filo-pointer filo-pointer--top filo-pointer--active">top = ${index}</span>` : ""}${isBase ? `<span class="filo-pointer filo-pointer--base">base = 0</span>` : ""}</div><div class="filo-node ${isTop ? "filo-node--top filo-node--focus" : ""} ${isBase ? "filo-node--base" : ""}"><span class="filo-node__label">acciones[${index}]</span><strong>${escapeFiloHtml(accion)}</strong><small>índice ${index}${isTop ? " · cima actual" : ""}${isBase ? " · base" : ""}</small></div></div>`;
                })
                .join(`<div class="filo-arrow-down"><strong>↓</strong></div>`);
        }

        if (historyList) {
          historyList.innerHTML = filoHistory.length === 0
            ? `<li class="filo-history__empty">Sin acciones deshechas aún.</li>`
            : filoHistory.map((accion) => `<li>${escapeFiloHtml(accion)}</li>`).join("");
        }

        if (traceList) {
          traceList.innerHTML = filoTrace.map((line) => `<li>${escapeFiloHtml(line)}</li>`).join("");
        }

        setFiloCodeHighlights(activeCode, relatedCode);
      }

      function showFiloFeedback(message, warn = false) {
        if (!(feedback instanceof HTMLElement)) return;
        feedback.textContent = message;
        feedback.style.color = warn ? "var(--danger)" : "var(--text-2)";
      }

      function pushFiloAction() {
        if (!(inputAccion instanceof HTMLInputElement)) return;
        const action = inputAccion.value.trim().replace(/[<>]/g, "");
        if (!action) {
          showFiloFeedback("Escribe el nombre de la acción antes de registrarla.", true);
          inputAccion.focus();
          return;
        }

        filoStack.push(action);
        pushFiloTrace(`push("${action}") → top = ${filoStack.length - 1}, size = ${filoStack.length}`, `acciones[${filoStack.length - 1}] = "${action}"`);
        showFiloFeedback(`Se registró "${action}" en la cima de la pila.`);
        updateFiloState({
          op: `push("${action}")`,
          detail: `La acción se apila encima. top avanza a ${filoStack.length - 1}.`,
          code: "Sección push: top++ y almacena la acción en acciones[top].",
          activeCode: "push-insert",
          relatedCode: ["stack-fields"],
        });
        inputAccion.value = "";
        inputAccion.focus();
      }

      function popFiloAction() {
        if (filoStack.length === 0) {
          showFiloFeedback("No hay acciones en la pila. Registra alguna primero.", true);
          pushFiloTrace("pop() abortado → pila vacía (top = -1)");
          updateFiloState({
            op: "pop() - pila vacía",
            detail: "top = -1. No existe elemento en la cima.",
            code: "Sección pop: estaVacia() devuelve true.",
            activeCode: "is-empty",
          });
          return;
        }

        const action = filoStack.pop();
        if (!action) return;
        filoHistory = [action, ...filoHistory].slice(0, 10);
        pushFiloTrace(`pop() → "${action}" · top = ${filoStack.length - 1}, size = ${filoStack.length}`, `acciones[${filoStack.length}] = null`);
        showFiloFeedback(`Se deshizo "${action}" correctamente.`);
        updateFiloState({
          op: `pop() → "${action}"`,
          detail: `La acción abandona la cima. top retrocede a ${filoStack.length - 1}.`,
          code: "Sección pop: devuelve acciones[top] y retrocede el puntero.",
          activeCode: "pop-extract",
          relatedCode: ["stack-fields"],
        });
      }

      function resetFilo() {
        filoStack = [...accionesFiloIniciales];
        filoHistory = [];
        filoTrace = [`reset → top = ${filoStack.length - 1}, size = ${filoStack.length}`, "Historial de deshechos borrado."];
        if (inputAccion instanceof HTMLInputElement) inputAccion.value = "";
        showFiloFeedback("La simulación volvió al estado inicial.");
        updateFiloState({
          op: "Reset de simulación",
          detail: "La pila volvió a su configuración original con tres acciones y sin historial.",
          code: "Se restauran el arreglo y el puntero top.",
          activeCode: "stack-fields",
          relatedCode: ["constructor"],
        });
      }

      btnPush?.addEventListener("click", pushFiloAction);
      btnPop?.addEventListener("click", popFiloAction);
      btnReset?.addEventListener("click", resetFilo);
      inputAccion?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") pushFiloAction();
      });

      resetFilo();
    }

    const filo2StackRoot = document.querySelector("#filo2-stack");
    if (filo2StackRoot) {
      const inputNombre = document.querySelector("#filo2-nombre");
      const selectCat = document.querySelector("#filo2-cat");
      const selectPrio = document.querySelector("#filo2-prio");
      const btnPush = document.querySelector("#filo2-push");
      const btnPop = document.querySelector("#filo2-pop");
      const btnReset = document.querySelector("#filo2-reset");
      const feedback = document.querySelector("#filo2-feedback");
      const topVal = document.querySelector("#filo2-top-val");
      const countVal = document.querySelector("#filo2-count");
      const lastVal = document.querySelector("#filo2-last");
      const opName = document.querySelector("#filo2-op-name");
      const opDetail = document.querySelector("#filo2-op-detail");
      const opCode = document.querySelector("#filo2-op-code");
      const structPanel = document.querySelector("#filo2-structure");
      const historyList = document.querySelector("#filo2-history");
      const traceList = document.querySelector("#filo2-trace");
      const tableBody = document.querySelector("#filo2-tabla");
      const filo2CodeBlocks = Array.from(document.querySelectorAll("[data-filo2-code-block]"));

      const solicitudesIniciales = [
        { codigo: "S003", nombre: "Error de acceso al sistema", categoria: "Seguridad", prioridad: "Alta", timestamp: "08:12" },
        { codigo: "S002", nombre: "VPN no conecta", categoria: "Red", prioridad: "Media", timestamp: "08:08" },
        { codigo: "S001", nombre: "Pantalla sin señal", categoria: "Hardware", prioridad: "Baja", timestamp: "08:03" },
      ];
      const catIcons = { Red: "NET", Seguridad: "SEC", Hardware: "HW", Software: "SW", "Base de datos": "DB" };
      let pilaFilo2 = solicitudesIniciales.map((solicitud) => ({ ...solicitud }));
      let historialFilo2 = [];
      let trazasFilo2 = ["[INIT] top = S003, size = 3", "S003.next -> S002 · S002.next -> S001 · S001.next -> null"];
      let siguienteFilo2 = 4;

      function escapeFilo2Html(value) {
        return String(value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/\"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function codigoFilo2() {
        return `S${String(siguienteFilo2++).padStart(3, "0")}`;
      }

      function horaFilo2() {
        return new Date().toLocaleTimeString("es-CO", { hour: "2-digit", minute: "2-digit" });
      }

      function prioridadBadge(prioridad) {
        const clase = { Alta: "prio-alta", Media: "prio-media", Baja: "prio-baja" }[prioridad] ?? "prio-baja";
        return `<span class="prio-badge ${clase}">${escapeFilo2Html(prioridad)}</span>`;
      }

      function setFilo2CodeHighlights(active, related = []) {
        for (const block of filo2CodeBlocks) {
          const key = block instanceof HTMLElement ? block.dataset.filo2CodeBlock : "";
          block.classList.toggle("filo-code-block--active", key === active);
          block.classList.toggle("filo-code-block--related", related.includes(key ?? ""));
        }
      }

      function pushFilo2Trace(...lines) {
        trazasFilo2 = [...lines, ...trazasFilo2].slice(0, 10);
      }

      function showFilo2Feedback(message, warn = false) {
        if (!(feedback instanceof HTMLElement)) return;
        feedback.textContent = message;
        feedback.style.color = warn ? "var(--danger)" : "var(--text-2)";
      }

      function renderFilo2({ op = "Estado actual", detail = "", code = "Atributos de la pila.", activeCode = "stack-fields", relatedCode = [] } = {}) {
        const top = pilaFilo2[0] ?? null;
        if (topVal) topVal.textContent = top ? top.nombre : "- (pila vacía)";
        if (countVal) countVal.textContent = `${pilaFilo2.length} solicitud${pilaFilo2.length === 1 ? "" : "es"}`;
        if (lastVal) lastVal.textContent = historialFilo2[0]?.nombre ?? "Aún no hay registros";
        if (opName) opName.textContent = op;
        if (opDetail) opDetail.textContent = detail;
        if (opCode) opCode.textContent = code;

        filo2StackRoot.innerHTML = pilaFilo2.length === 0
          ? `<p class="filo-stack__empty">La pila está vacía.</p>`
          : pilaFilo2.map((nodo, index) => `
              <div class="filo-turno ${index === 0 ? "filo-turno--top filo-turno--focus" : ""}">
                <span>${index === 0 ? "Cima - top" : "Nodo"}</span>
                <strong>${catIcons[nodo.categoria] ?? ""} ${escapeFilo2Html(nodo.nombre)}</strong>
                <p>${escapeFilo2Html(nodo.codigo)} · ${escapeFilo2Html(nodo.categoria)} · ${escapeFilo2Html(nodo.timestamp)}</p>
                ${prioridadBadge(nodo.prioridad)}
              </div>
            `).join("");

        if (structPanel) {
          structPanel.innerHTML = pilaFilo2.length === 0
            ? `<div class="filo-stack-empty"><p>top = null · La pila no contiene solicitudes.</p></div>`
            : pilaFilo2.map((nodo, index) => {
                const isTop = index === 0;
                const isBase = index === pilaFilo2.length - 1;
                const nextLabel = isBase ? "null" : pilaFilo2[index + 1].codigo;
                return `<div class="filo-stack-piece">
                  <div class="filo-pointer-row">${isTop ? `<span class="filo-pointer filo-pointer--top filo-pointer--active">top -> ${escapeFilo2Html(nodo.codigo)}</span>` : ""}${isBase ? `<span class="filo-pointer filo-pointer--base">base (next = null)</span>` : ""}</div>
                  <div class="filo-node ${isTop ? "filo-node--top filo-node--focus" : ""} ${isBase ? "filo-node--base" : ""}">
                    <span class="filo-node__label">${escapeFilo2Html(nodo.codigo)}${isTop ? " · cima" : ""}${isBase ? " · base" : ""}</span>
                    <strong>${escapeFilo2Html(nodo.nombre)}</strong>
                    <small>${escapeFilo2Html(nodo.categoria)} · next -> ${escapeFilo2Html(nextLabel)}</small>
                  </div>
                </div>`;
              }).join(`<div class="filo-arrow-down"><strong>↓</strong></div>`);
        }

        if (tableBody) {
          tableBody.innerHTML = pilaFilo2.length === 0
            ? `<tr><td colspan="6" class="filo-table-empty">La pila está vacía.</td></tr>`
            : pilaFilo2.map((nodo, index) => `<tr class="${index === 0 ? "td-top" : ""}">
                <td class="td-code">${escapeFilo2Html(nodo.codigo)}</td>
                <td>${catIcons[nodo.categoria] ?? ""} ${escapeFilo2Html(nodo.nombre)}</td>
                <td>${escapeFilo2Html(nodo.categoria)}</td>
                <td>${prioridadBadge(nodo.prioridad)}</td>
                <td>${index === 0 ? "Cima (top)" : index === pilaFilo2.length - 1 ? "Base" : `Posición ${index + 1}`}</td>
                <td>${escapeFilo2Html(nodo.timestamp)}</td>
              </tr>`).join("");
        }

        if (historyList) {
          historyList.innerHTML = historialFilo2.length === 0
            ? `<li class="filo-history__empty">Todavía no se ha resuelto ninguna solicitud.</li>`
            : historialFilo2.map((nodo) => `<li><span class="hist-code">${escapeFilo2Html(nodo.codigo)}</span>${escapeFilo2Html(nodo.nombre)} ${prioridadBadge(nodo.prioridad)}</li>`).join("");
        }

        if (traceList) {
          traceList.innerHTML = trazasFilo2.map((line) => `<li>${escapeFilo2Html(line)}</li>`).join("");
        }

        setFilo2CodeHighlights(activeCode, relatedCode);
      }

      function registrarSolicitudFilo2() {
        if (!(inputNombre instanceof HTMLInputElement)) return;
        const nombre = inputNombre.value.trim().replace(/[<>]/g, "");
        if (!nombre) {
          showFilo2Feedback("Escribe el nombre del problema antes de registrarlo.", true);
          inputNombre.focus();
          return;
        }

        const categoria = selectCat instanceof HTMLSelectElement ? selectCat.value : "Red";
        const prioridad = selectPrio instanceof HTMLSelectElement ? selectPrio.value : "Media";
        const anteriorTop = pilaFilo2[0]?.codigo ?? "null";
        const nuevo = { codigo: codigoFilo2(), nombre, categoria, prioridad, timestamp: horaFilo2() };
        pilaFilo2 = [nuevo, ...pilaFilo2];
        pushFilo2Trace(`push(${nuevo.codigo}) -> top = ${nuevo.codigo}, next -> ${anteriorTop}, size = ${pilaFilo2.length}`);
        showFilo2Feedback(`Se registró "${nombre}" (${nuevo.codigo}) en la cima de la pila.`);
        renderFilo2({
          op: `push("${nuevo.codigo}")`,
          detail: `"${nombre}" se apila encima. top avanza a ${nuevo.codigo}. next del nuevo nodo apunta al anterior top.`,
          code: "Sección push: nuevo.next = top, luego top = nuevo.",
          activeCode: "push-insert",
          relatedCode: ["node-class", "stack-fields"],
        });
        inputNombre.value = "";
        inputNombre.focus();
      }

      function resolverSolicitudFilo2() {
        if (pilaFilo2.length === 0) {
          showFilo2Feedback("No hay solicitudes en la pila. Registra alguna primero.", true);
          pushFilo2Trace("pop() abortado -> pila vacía (top = null)");
          renderFilo2({ op: "pop() - pila vacía", detail: "top = null. No existe solicitud en la cima.", code: "Sección pop: estaVacia() devuelve true.", activeCode: "is-empty" });
          return;
        }

        const [resuelta, ...resto] = pilaFilo2;
        pilaFilo2 = resto;
        historialFilo2 = [resuelta, ...historialFilo2].slice(0, 10);
        const nuevoTop = pilaFilo2[0]?.codigo ?? "null";
        pushFilo2Trace(`pop() -> ${resuelta.codigo} "${resuelta.nombre}" · top = ${nuevoTop}, size = ${pilaFilo2.length}`);
        showFilo2Feedback(`Se resolvió "${resuelta.nombre}" (${resuelta.codigo}) correctamente.`);
        renderFilo2({
          op: `pop() -> "${resuelta.codigo}"`,
          detail: `"${resuelta.nombre}" abandona la cima. top avanza a ${nuevoTop}.`,
          code: "Sección pop: resuelto = top, top = top.next, size--.",
          activeCode: "pop-extract",
          relatedCode: ["stack-fields"],
        });
      }

      function resetFilo2() {
        pilaFilo2 = solicitudesIniciales.map((solicitud) => ({ ...solicitud }));
        historialFilo2 = [];
        trazasFilo2 = ["reset -> top = S003, size = 3", "S003.next -> S002 · S002.next -> S001 · S001.next -> null"];
        siguienteFilo2 = 4;
        if (inputNombre instanceof HTMLInputElement) inputNombre.value = "";
        showFilo2Feedback("La simulación volvió al estado inicial.");
        renderFilo2({
          op: "Reset de simulación",
          detail: "La pila volvió a su configuración original con tres solicitudes y sin historial.",
          code: "Se restauran los nodos enlazados y el puntero top con los valores iniciales.",
          activeCode: "stack-fields",
          relatedCode: ["node-class"],
        });
      }

      btnPush?.addEventListener("click", registrarSolicitudFilo2);
      btnPop?.addEventListener("click", resolverSolicitudFilo2);
      btnReset?.addEventListener("click", resetFilo2);
      inputNombre?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") registrarSolicitudFilo2();
      });

      resetFilo2();
    }
  </script>
</BaseLayout>

