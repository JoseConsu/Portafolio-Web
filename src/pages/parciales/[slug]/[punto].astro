    padding: var(--sp-5);
    border: 1px solid var(--br-1);
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(15, 23, 42, 0.78));
    border-radius: 24px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
