    box-shadow: var(--sh-sm);
  }

  .fifo-node--front {
    border-color: color-mix(in srgb, var(--terra) 45%, transparent);
  }

  .fifo-node--rear {
    border-color: color-mix(in srgb, var(--success) 35%, transparent);
  }

  .fifo-node--focus {
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--terra) 22%, transparent), 0 16px 28px rgba(0, 0, 0, 0.25);
  }

  .fifo-node--incoming {
    animation: fifoNodeEnter 340ms ease;
  }

  .fifo-node--outgoing {
    animation: fifoNodeExit 340ms ease;
  }

  .fifo-node--front-active {
    border-color: color-mix(in srgb, var(--terra) 55%, transparent);
  }

  .fifo-node--rear-active {
    border-color: color-mix(in srgb, var(--success) 55%, transparent);
  }

  .fifo-node__label {
    display: block;
    margin-bottom: var(--sp-2);
    font-family: var(--ff-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .fifo-node p,
  .fifo-node small {
    margin: var(--sp-2) 0 0;
    color: var(--text-2);
  }

  .fifo-arrow {
    display: grid;
    place-items: center;
    gap: var(--sp-1);
    min-width: 78px;
    color: var(--text-3);
  }

  .fifo-arrow strong {
