---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { readFile } from "node:fs/promises";
import { join, normalize, relative, resolve, sep } from "node:path";
import { parciales } from "../../../parciales/parciales";

export function getStaticPaths() {
  return parciales
    .flatMap((parcial) =>
      parcial.puntos
        .filter((punto) => parcial.slug === "proyecto-final" || punto.rutaCodigo)
        .map((punto) => ({
          params: { slug: parcial.slug, punto: punto.slug },
          props: { parcial, punto },
        }))
    );
}

const { parcial, punto } = Astro.props;
const esProyectoFinal = parcial.slug === "proyecto-final";
const esFifo1 = esProyectoFinal && punto.slug === "fifo-1";
const esPlaceholderProyectoFinal = esProyectoFinal && !esFifo1;

async function leerArchivoPublico(rutaPublica: string, contexto: string) {
  const rutaRelativa = normalize(rutaPublica.replace(/^\/+/, ""));
  const basePublica = resolve(process.cwd(), "public");
  const absoluta = resolve(basePublica, rutaRelativa);
  const rutaDesdePublic = relative(basePublica, absoluta);
  const esFueraDePublic = rutaDesdePublic.startsWith("..") || rutaDesdePublic.includes(`..${sep}`);

  if (esFueraDePublic) {
    throw new Error(`[parciales] Ruta invalida fuera de public para ${contexto}: ${rutaPublica}`);
  }

  try {
    return await readFile(absoluta, "utf-8");
  } catch (error) {
    const detalle = error instanceof Error ? error.message : String(error);
    throw new Error(`[parciales] No se pudo leer ${contexto} en ${join("public", rutaRelativa)}: ${detalle}`);
  }
}

const codigoPlantilla = punto.rutaCodigo ? await leerArchivoPublico(punto.rutaCodigo, `${parcial.slug}/${punto.slug}`) : null;
const turnosIniciales = [
  { codigo: "A001", nombre: "Laura Diaz" },
  { codigo: "A002", nombre: "Carlos Mejia" },
  { codigo: "A003", nombre: "Sofia Rojas" },
];
const codigoJavaFifo1 = `import java.util.LinkedList;
import java.util.Queue;

public class ColaTurnosBanco {
  private final Queue<Turno> cola = new LinkedList<>();

  public void encolar(String codigo, String nombre) {
    cola.offer(new Turno(codigo, nombre));
  }

  public Turno atenderSiguiente() {
    return cola.poll();
  }

  public Turno verFrente() {
    return cola.peek();
  }

  public boolean estaVacia() {
    return cola.isEmpty();
  }

  record Turno(String codigo, String nombre) {}
}`;
---

<BaseLayout title={`${punto.nombre} | ${parcial.titulo}`}>
  {esFifo1 ? (
    <main class="fifo-shell" id="contenido-principal">
      <section class="fifo-hero">
        <div class="fifo-hero__copy">
          <p class="ds-eyebrow">Proyecto final · Aplicativo disponible</p>
          <h1>{punto.nombre}</h1>
          <p class="fifo-hero__lead">
            Sistema web de turnos bancarios que aplica una cola FIFO para atender clientes exactamente en el orden en el que llegan.
          </p>
          <div class="fifo-hero__actions">
            <a class="btn btn-primary" href="#demo-fifo">Probar demo</a>
            <a class="btn btn-ghost" href={`/parciales/${parcial.slug}`}>Volver al catálogo</a>
          </div>
        </div>

        <div class="fifo-hero__panel ds-panel">
          <div class="hero-kpis">
            <article>
              <span>Estructura</span>
              <strong>FIFO</strong>
            </article>
            <article>
              <span>Contexto</span>
              <strong>Atención bancaria</strong>
            </article>
            <article>
              <span>Stack lógico</span>
              <strong>Java</strong>
            </article>
          </div>
          <div class="turno-preview" aria-label="Vista previa de turnos">
            {turnosIniciales.map((turno, index) => (
              <div class={`turno-preview__item ${index === 0 ? "turno-preview__item--front" : ""}`}>
                <span>{turno.codigo}</span>
                <strong>{turno.nombre}</strong>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="fifo-grid-info">
        <article class="ds-panel fifo-info-card">
          <p class="ds-eyebrow">Problema</p>
          <h2>Orden y trazabilidad en cajas</h2>
          <p>
            En un banco, cada cliente espera que el sistema respete su llegada. Una cola FIFO permite registrar turnos,
            mantener el frente visible y garantizar una atencion justa sin saltos manuales.
          </p>
        </article>

        <article class="ds-panel fifo-info-card">
          <p class="ds-eyebrow">Aplicación al desarrollo</p>
          <h2>De estructura a producto web</h2>
          <p>
            La misma estructura sirve para un modulo de recepcion, ventanillas, kioscos de autogestion y tableros de seguimiento.
            En esta version el frontend ilustra el flujo y la logica Java modela la cola del sistema.
          </p>
        </article>
      </section>

      <section class="fifo-flow ds-panel">
        <div>
          <p class="ds-eyebrow">Funcionamiento</p>
          <h2>Secuencia operativa de la cola</h2>
        </div>
        <div class="fifo-flow__steps">
          <article>
            <span>01</span>
            <h3>Tomar turno</h3>
            <p>El cliente ingresa al sistema y recibe un codigo consecutivo junto con su nombre.</p>
          </article>
          <article>
            <span>02</span>
            <h3>Encolar</h3>
            <p>El turno se agrega al final de la cola manteniendo intacto el orden de llegada.</p>
          </article>
          <article>
            <span>03</span>
            <h3>Atender</h3>
            <p>La caja siempre toma el primer turno disponible y lo mueve al historial.</p>
          </article>
        </div>
      </section>

      <section class="fifo-demo ds-panel" id="demo-fifo">
        <div class="fifo-demo__head">
          <div>
            <p class="ds-eyebrow">Demo interactiva</p>
            <h2>Simulación del turnero bancario</h2>
            <p>Agrega clientes, atiende el siguiente turno y observa cómo la cola respeta FIFO en tiempo real.</p>
          </div>
          <div class="fifo-demo__actions">
            <button class="btn btn-primary" id="fifo-add" type="button">Agregar turno</button>
            <button class="btn btn-secondary" id="fifo-next" type="button">Atender siguiente</button>
            <button class="btn btn-ghost" id="fifo-reset" type="button">Reiniciar</button>
          </div>
        </div>

        <div class="fifo-form">
          <label for="fifo-name">Nombre del cliente</label>
          <input id="fifo-name" name="fifo-name" type="text" placeholder="Ej. Mariana Torres" autocomplete="off" />
          <p id="fifo-feedback" class="fifo-feedback" aria-live="polite">La cola inicia con tres turnos de ejemplo para mostrar el comportamiento base.</p>
        </div>

        <div class="fifo-dashboard">
          <article>
            <span>Turno en atención</span>
            <strong id="fifo-current">A001 · Laura Diaz</strong>
          </article>
          <article>
            <span>En espera</span>
            <strong id="fifo-count">3 clientes</strong>
          </article>
          <article>
            <span>Último atendido</span>
            <strong id="fifo-last">Aun no hay registros</strong>
          </article>
        </div>

        <div class="fifo-demo__content">
          <div class="fifo-queue-panel">
            <div class="fifo-section-head">
              <h3>Cola actual</h3>
              <span>Primer turno visible al frente</span>
            </div>
            <div class="fifo-queue" id="fifo-queue" aria-live="polite"></div>
          </div>

          <div class="fifo-history-panel">
            <div class="fifo-section-head">
              <h3>Historial de atención</h3>
              <span>Salida en orden de servicio</span>
            </div>
            <ul id="fifo-history" class="fifo-history"></ul>
          </div>
        </div>
      </section>

      <section class="ds-panel zona-codigo zona-codigo--java">
        <div class="encabezado-cuadro">
          <h2><img src="/icons/rocket.svg" alt="" class="ui-icon" aria-hidden="true" />Lógica Java de la cola</h2>
          <span class="codigo-badge">Referencia conceptual</span>
        </div>
        <pre class="cuadro-codigo"><code>{codigoJavaFifo1}</code></pre>
      </section>
    </main>
  ) : esPlaceholderProyectoFinal ? (
    <main class="placeholder-shell" id="contenido-principal">
      <section class="program-hero">
        <img src="/programas-temporales/uis-logo.svg" alt="Logotipo de la Universidad Industrial de Santander" loading="eager" decoding="async" />
        <div>
          <p class="ds-eyebrow">{parcial.titulo}</p>
          <h1>{punto.nombre}</h1>
          <p>{punto.descripcion}</p>
        </div>
        <a class="icono-volver" href={`/parciales/${parcial.slug}`} aria-label="Volver al catálogo de aplicativos" title="Volver al catálogo de aplicativos">
          <img src="/icons/folder.svg" alt="" class="ui-icon" aria-hidden="true" />
        </a>
      </section>

      <section class="ds-panel placeholder-card">
        <span class="placeholder-pill">Próximamente</span>
        <h2>Este aplicativo forma parte del roadmap del proyecto final</h2>
        <p>
          La estructura base ya quedó preparada para recibir esta nueva experiencia. Cuando se implemente,
          conservará el mismo patrón de navegación, detalle y demo usado en FIFO 1.
        </p>
        <div class="placeholder-actions">
          <a class="btn btn-primary" href={`/parciales/${parcial.slug}`}>Volver al catálogo</a>
          <a class="btn btn-ghost" href={`/parciales/${parcial.slug}/fifo-1`}>Ver FIFO 1</a>
        </div>
      </section>
    </main>
  ) : (
    <main class="programa-shell" id="contenido-principal">
      <section class="program-hero">
        <img src="/programas-temporales/uis-logo.svg" alt="Logotipo de la Universidad Industrial de Santander" loading="eager" decoding="async" />
        <div>
          <p class="ds-eyebrow">{parcial.titulo}</p>
          <h1>{punto.nombre}</h1>
          <p>{punto.descripcion}</p>
        </div>
        <a class="icono-volver" href={`/parciales/${parcial.slug}`} aria-label="Volver al listado de puntos" title="Volver al listado de puntos">
          <img src="/icons/folder.svg" alt="" class="ui-icon" aria-hidden="true" />
        </a>
      </section>

      {codigoPlantilla && (
        <section class="ds-panel zona-codigo">
          <div class="encabezado-cuadro">
            <h2><img src="/icons/rocket.svg" alt="" class="ui-icon" aria-hidden="true" />Código del punto</h2>
            {parcial.slug === "parcial-01" && (
              <button class="boton-copiar" type="button" aria-label="Copiar codigo">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                  <path d="M8 7a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-9a2 2 0 0 1-2-2V7Zm2 0h9v11h-9V7Z" />
                  <path d="M5 4a2 2 0 0 1 2-2h9v2H7v11H5V4Zm-2 5h2v11a2 2 0 0 0 2 2h11v2H7a2 2 0 0 1-2-2V9Z" />
                </svg>
              </button>
            )}
          </div>
          <pre class="cuadro-codigo"><code>{codigoPlantilla}</code></pre>
        </section>
      )}

      {punto.rutaImagen && (
        <section class="ds-panel zona-imagen">
          <h2><img src="/icons/flask.svg" alt="" class="ui-icon" aria-hidden="true" />Output del punto</h2>
          <div class="marco-imagen">
            <img
              src={punto.rutaImagen}
              alt={`Imagen de salida de ${punto.nombre}`}
              loading="lazy"
              decoding="async"
            />
          </div>
        </section>
      )}
    </main>
  )}

  <script is:inline define:vars={{ turnosIniciales }}>
    const botonCopiar = document.querySelector(".boton-copiar");
    const nodoCodigo = document.querySelector(".cuadro-codigo");

    botonCopiar?.addEventListener("click", async () => {
      if (!nodoCodigo) return;

      const texto = nodoCodigo.textContent ?? "";
      const iconoOriginal = botonCopiar?.querySelector("svg")?.cloneNode(true);

      try {
        await navigator.clipboard.writeText(texto);
        botonCopiar.textContent = "✅";
        setTimeout(() => {
          botonCopiar?.replaceChildren();
          if (iconoOriginal) {
            botonCopiar?.appendChild(iconoOriginal.cloneNode(true));
          }
        }, 1400);
      } catch {
        const seleccion = window.getSelection();
        const rango = document.createRange();
        rango.selectNodeContents(nodoCodigo);
        seleccion?.removeAllRanges();
        seleccion?.addRange(rango);
      }
    });

    const queueRoot = document.querySelector("#fifo-queue");
    if (queueRoot) {
      const historyRoot = document.querySelector("#fifo-history");
      const feedbackNode = document.querySelector("#fifo-feedback");
      const inputNode = document.querySelector("#fifo-name");
      const currentNode = document.querySelector("#fifo-current");
      const countNode = document.querySelector("#fifo-count");
      const lastNode = document.querySelector("#fifo-last");
      const addButton = document.querySelector("#fifo-add");
      const nextButton = document.querySelector("#fifo-next");
      const resetButton = document.querySelector("#fifo-reset");

      const initialQueue = turnosIniciales.map((turno) => ({ ...turno }));
      let queue = initialQueue.map((turno) => ({ ...turno }));
      let history = [];
      let nextId = initialQueue.length + 1;

      const formatoTurno = (turno) => `${turno.codigo} · ${turno.nombre}`;

      const render = () => {
        if (currentNode) {
          currentNode.textContent = queue[0] ? formatoTurno(queue[0]) : "Sin clientes en espera";
        }

        if (countNode) {
          const total = queue.length;
          countNode.textContent = `${total} ${total === 1 ? "cliente" : "clientes"}`;
        }

        if (lastNode) {
          lastNode.textContent = history[0] ? formatoTurno(history[0]) : "Aun no hay registros";
        }

        queueRoot.replaceChildren();

        if (queue.length === 0) {
          const empty = document.createElement("div");
          empty.className = "fifo-queue__empty";
          empty.textContent = "La cola está vacía. Agrega un nuevo turno para continuar la simulación.";
          queueRoot.appendChild(empty);
        } else {
          queue.forEach((turno, index) => {
            const card = document.createElement("article");
            card.className = `fifo-turno ${index === 0 ? "fifo-turno--front" : ""}`;
            card.innerHTML = `<span>${index === 0 ? "En frente" : `Posición ${index + 1}`}</span><strong>${turno.codigo}</strong><p>${turno.nombre}</p>`;
            queueRoot.appendChild(card);
          });
        }

        historyRoot?.replaceChildren();

        if (history.length === 0) {
          const item = document.createElement("li");
          item.className = "fifo-history__empty";
          item.textContent = "Todavía no se ha atendido ningún cliente.";
          historyRoot?.appendChild(item);
        } else {
          history.forEach((turno) => {
            const item = document.createElement("li");
            item.textContent = formatoTurno(turno);
            historyRoot?.appendChild(item);
          });
        }
      };

      addButton?.addEventListener("click", () => {
        const nombre = inputNode instanceof HTMLInputElement ? inputNode.value.trim() : "";
        if (!nombre) {
          if (feedbackNode) {
            feedbackNode.textContent = "Ingresa el nombre del cliente antes de generar un nuevo turno.";
          }
          inputNode?.focus();
          return;
        }

        const codigo = `A${String(nextId).padStart(3, "0")}`;
        nextId += 1;
        queue.push({ codigo, nombre });
        if (feedbackNode) {
          feedbackNode.textContent = `Se agregó ${codigo} para ${nombre} al final de la cola.`;
        }
        if (inputNode instanceof HTMLInputElement) {
          inputNode.value = "";
          inputNode.focus();
        }
        render();
      });

      nextButton?.addEventListener("click", () => {
        if (queue.length === 0) {
          if (feedbackNode) {
            feedbackNode.textContent = "No hay clientes en espera. Agrega un nuevo turno para continuar.";
          }
          render();
          return;
        }

        const atendido = queue.shift();
        if (atendido) {
          history.unshift(atendido);
          if (feedbackNode) {
            feedbackNode.textContent = `${atendido.codigo} de ${atendido.nombre} fue atendido correctamente.`;
          }
        }
        render();
      });

      resetButton?.addEventListener("click", () => {
        queue = initialQueue.map((turno) => ({ ...turno }));
        history = [];
        nextId = initialQueue.length + 1;
        if (inputNode instanceof HTMLInputElement) {
          inputNode.value = "";
        }
        if (feedbackNode) {
          feedbackNode.textContent = "La simulación volvió al estado inicial con los turnos de ejemplo.";
        }
        render();
      });

      render();
    }
  </script>
</BaseLayout>

<style>
  .fifo-shell,
  .placeholder-shell {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
    padding: var(--sp-6) 0 var(--sp-7);
  }

  .fifo-shell {
    display: grid;
    gap: var(--sp-5);
  }

  .fifo-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: var(--sp-5);
    align-items: stretch;
  }

  .fifo-hero__copy,
  .fifo-hero__panel,
  .placeholder-card {
    border-radius: 28px;
  }

  .fifo-hero__copy {
    padding: var(--sp-6);
    background:
      radial-gradient(circle at top left, rgba(231, 160, 94, 0.22), transparent 40%),
      linear-gradient(160deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.8));
    border: 1px solid var(--br-1);
    box-shadow: var(--sh-card);
  }

  .fifo-hero__copy h1 {
    margin: 0 0 var(--sp-3);
    font-size: clamp(2.2rem, 4.2vw, 3.8rem);
    line-height: 1.05;
  }

  .fifo-hero__lead {
    max-width: 58ch;
    color: var(--text-2);
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .fifo-hero__actions,
  .placeholder-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-4);
  }

  .hero-kpis {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
  }

  .hero-kpis article,
  .fifo-dashboard article {
    padding: var(--sp-3);
    border-radius: 18px;
    border: 1px solid var(--br-1);
    background: rgba(255, 255, 255, 0.03);
  }

  .hero-kpis span,
  .fifo-dashboard span,
  .fifo-section-head span,
  .codigo-badge,
  .placeholder-pill {
    display: inline-block;
    font-family: var(--ff-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .hero-kpis strong,
  .fifo-dashboard strong {
    display: block;
    margin-top: var(--sp-1);
    font-size: 1rem;
    color: var(--text-1);
  }

  .turno-preview {
    display: grid;
    gap: var(--sp-3);
  }

  .turno-preview__item,
  .fifo-turno {
    padding: var(--sp-4);
    border-radius: 20px;
    border: 1px solid var(--br-1);
    background: rgba(9, 15, 28, 0.7);
  }

  .turno-preview__item span,
  .fifo-turno span {
    display: block;
    margin-bottom: var(--sp-1);
    font-family: var(--ff-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-3);
  }

  .turno-preview__item strong,
  .fifo-turno strong {
    display: block;
    color: var(--text-1);
    font-size: 1.05rem;
  }

  .turno-preview__item--front,
  .fifo-turno--front {
    border-color: color-mix(in srgb, var(--terra) 45%, transparent);
    background: linear-gradient(135deg, rgba(231, 160, 94, 0.18), rgba(12, 22, 42, 0.82));
  }

  .fifo-grid-info,
  .fifo-demo__content {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--sp-4);
  }

  .fifo-info-card h2,
  .fifo-flow h2,
  .fifo-demo__head h2,
  .placeholder-card h2 {
    margin-bottom: var(--sp-2);
  }

  .fifo-info-card p,
  .fifo-flow p,
  .fifo-demo__head p,
  .placeholder-card p {
    color: var(--text-2);
    line-height: 1.7;
  }

  .fifo-flow {
    display: grid;
    gap: var(--sp-4);
  }

  .fifo-flow__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-4);
  }

  .fifo-flow__steps article {
    padding: var(--sp-4);
    border-radius: 22px;
    border: 1px solid var(--br-1);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
  }

  .fifo-flow__steps article span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.3rem;
    height: 2.3rem;
    margin-bottom: var(--sp-3);
    border-radius: 999px;
    background: rgba(231, 160, 94, 0.14);
    color: var(--terra-light);
    font-weight: 700;
  }

  .fifo-demo {
    display: grid;
    gap: var(--sp-4);
  }

  .fifo-demo__head,
  .fifo-dashboard,
  .fifo-section-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--sp-4);
  }

  .fifo-demo__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .fifo-form {
    display: grid;
    gap: var(--sp-2);
  }

  .fifo-form label {
    font-weight: 600;
    color: var(--text-1);
  }

  .fifo-form input {
    width: 100%;
    border-radius: 16px;
    border: 1px solid var(--br-1);
    background: rgba(10, 18, 32, 0.9);
    color: var(--text-1);
    padding: 0.9rem 1rem;
  }

  .fifo-feedback {
    color: var(--text-2);
    font-size: 0.95rem;
  }

  .fifo-dashboard {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-3);
  }

  .fifo-queue-panel,
  .fifo-history-panel,
  .placeholder-card {
    padding: var(--sp-5);
    border: 1px solid var(--br-1);
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(15, 23, 42, 0.78));
  }

  .fifo-queue {
    display: grid;
    gap: var(--sp-3);
    margin-top: var(--sp-4);
  }

  .fifo-turno p,
