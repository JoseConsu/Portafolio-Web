  private Nodo frente;
  private Nodo fin;
  private int size;

  private static class Nodo {
    String codigo;
    String nombre;
    int paginas;
    Nodo next;

    Nodo(String codigo, String nombre, int paginas) {
      this.codigo = codigo;
      this.nombre = nombre;
      this.paginas = paginas;
    }
  }

  public void encolar(String codigo, String nombre, int paginas) {
    Nodo nuevo = new Nodo(codigo, nombre, paginas);

    if (estaVacia()) {
      frente = nuevo;
      fin = nuevo;
    } else {
      fin.next = nuevo;
      fin = nuevo;
    }

    size++;
  }

  public String desencolar() {
    if (estaVacia()) return null;

    Nodo procesado = frente;
    frente = frente.next;

    if (frente == null) {
      fin = null;
    }

    size--;
    return procesado.codigo + " - " + procesado.nombre;
  }

  public boolean estaVacia() {
    return frente == null;
  }
}`}</code></pre>
